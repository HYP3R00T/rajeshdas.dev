{
  "file_types": {
    "Markdown": ["md", "mdx"]
  },
  "lsp": {
    "rumdl": {
      "binary": {
        "path": "rumdl",
        "arguments": ["server"]
      }
    }
  },
  "languages": {
    "Astro": {
      "formatter": "language_server",
      "format_on_save": "on"
    },
    "CSS": {
      "formatter": "language_server",
      "format_on_save": "on",
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
        "..."
      ]
    },
    "JavaScript": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "format_on_save": "on",
      "language_servers": [
        "biome",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TypeScript": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "format_on_save": "on",
      "language_servers": [
        "biome",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "formatter": {
        "language_server": {
          "name": "biome"
        }
      },
      "format_on_save": "on",
      "language_servers": [
        "biome",
        "..."
      ],
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JSON": {
      "formatter": "language_server",
      "format_on_save": "on"
    },
    "JSONC": {
      "formatter": "language_server",
      "format_on_save": "on"
    },
    "Markdown": {
      "formatter": "language_server",
      "format_on_save": "on",
      "language_servers": ["rumdl"]
    },
    "TOML": {
      "formatter": "language_server",
      "format_on_save": "on"
    },
    "YAML": {
      "formatter": "language_server",
      "format_on_save": "on"
    }
  }
}
