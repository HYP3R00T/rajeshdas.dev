{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@posts/*": [
        "./content/posts/*"
      ],
      "@data/*": [
        "./data/*"
      ]
    },
    "strictNullChecks": true,
    "allowJs": true
  }
}
