---
import type { HTMLAttributes } from "astro/types";

type PatternVariant = "none" | "stripe" | "stripe-dense";

interface Props extends HTMLAttributes<"section"> {
  pattern?: PatternVariant;
  class?: string;
  id?: string;
}

const { pattern = "none", class: className, id, ...rest } = Astro.props;
---

<section
  id={id}
  class:list={[
    "relative px-6 py-24 md:px-12 md:py-32",
    {
      "stripe-pattern": pattern === "stripe",
      "stripe-pattern-dense": pattern === "stripe-dense",
    },
    className?.trim(),
  ]}
  {...rest}
>
  <div class="mx-auto w-full max-w-7xl">
    <slot />
  </div>
</section>
