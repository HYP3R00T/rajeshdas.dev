---
interface Props {
  invertOnHover?: boolean;
}

const { invertOnHover = false } = Astro.props;
---

<div
  class:list={[
    "group relative border bg-transparent p-6 transition-colors duration-500 hover:z-10 -mr-px -mb-px",
    invertOnHover
      ? "border-border hover:border-foreground-0 hover:bg-foreground-0"
      : "border-border hover:bg-background-1",
  ]}
>
  <slot />
</div>
