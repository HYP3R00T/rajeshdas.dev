---
interface Props {
  invertOnHover?: boolean;
  class?: string;
}

const { invertOnHover = false, class: className } = Astro.props;
---

<div
  class:list={[
    "group relative border bg-transparent p-6 transition-colors duration-500 hover:z-10 -mr-px -mb-px",
    invertOnHover ? "border-border hover:border-foreground hover:bg-foreground" : "border-border hover:bg-card",
    className,
  ]}
>
  <slot />
</div>
