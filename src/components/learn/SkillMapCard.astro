---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import { getSkillMapSlug } from "@/lib/learn";

const { map, moduleCount = 0 } = Astro.props;
const href = `/learn/${getSkillMapSlug(map)}/`;
const cover = map.data.cover;
---

<a
  href={href}
  class="group grid h-full min-w-0 overflow-hidden rounded-lg border border-border/80 bg-background-1 p-3 transition-colors hover:bg-background-0 lg:grid-cols-2 lg:gap-4"
>
  <div class="aspect-video overflow-hidden rounded-md bg-background-1 lg:aspect-auto lg:min-h-56">
    {
      cover ? (
        <Image
          src={cover}
          alt={map.data.coverAlt || `${map.data.title} preview`}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          widths={[480, 720, 960]}
          sizes="(max-width: 1024px) 86vw, 460px"
        />
      ) : (
        <div class="h-full w-full bg-background-0" aria-hidden="true"></div>
      )
    }
  </div>

  <div class="flex min-h-full min-w-0 flex-col px-1 pt-4 pb-1 lg:px-4 lg:py-3 xl:px-5">
    <div class="flex min-w-0 items-start justify-between gap-6">
      <h2
        class="min-w-0 flex-1 font-display text-xl leading-tight text-foreground-0 xl:text-2xl"
        transition:name={`skill-map-title-${getSkillMapSlug(map)}`}
      >
        {map.data.title}
      </h2>
      <p class="shrink-0 font-mono text-xs tracking-[0.18em] text-foreground-3 uppercase">{moduleCount} module{moduleCount === 1 ? "" : "s"}</p>
    </div>
    <p class="mt-3 mb-6 text-sm leading-relaxed text-foreground-1 md:text-base">{map.data.description}</p>
    <div class="mt-auto pt-4 font-display text-sm font-medium text-foreground-1 transition-colors group-hover:text-foreground-0">
      <span class="inline-flex items-center gap-2">
        Open map
        <Icon name="arrow-up-right" class="size-4" />
      </span>
    </div>
  </div>
</a>
