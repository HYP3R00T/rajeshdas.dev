---
import { Icon } from "astro-icon/components";
import { getSkillMapSlug } from "@/lib/learn";

const { map, moduleCount = 0 } = Astro.props;
const href = `/learn/${getSkillMapSlug(map)}/`;
---

<a
  href={href}
  class="group block overflow-hidden rounded-lg border border-border bg-background-1 transition-colors hover:bg-background-0"
>
  <div class="flex min-h-56 items-center justify-center border-b border-border bg-background-2 p-8">
    <div class="flex size-24 items-center justify-center rounded-lg border border-border bg-background-1 text-accent-1">
      <Icon name="code" class="size-10" />
    </div>
  </div>

  <div class="p-6">
    <div class="flex items-start justify-between gap-6">
      <div>
        <h2 class="font-display text-3xl leading-tight text-foreground-0 transition-colors group-hover:text-accent-1">
          {map.data.title}
        </h2>
        <p class="mt-3 max-w-xl text-base leading-relaxed text-foreground-1">{map.data.description}</p>
      </div>
      <p class="shrink-0 font-mono text-xs tracking-[0.18em] text-foreground-3 uppercase">{moduleCount} module{moduleCount === 1 ? "" : "s"}</p>
    </div>
    <span class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-foreground-1 transition-colors group-hover:text-accent-1">
      Open map
      <Icon name="arrow-up-right" class="size-4" />
    </span>
  </div>
</a>
