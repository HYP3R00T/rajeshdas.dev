---
interface Props {
  invertOnHover?: boolean;
  class?: string;
}

const { invertOnHover = false, class: className } = Astro.props;
---

<div
  class:list={[
    "group relative border bg-background-0 p-6 transition-colors duration-500 hover:z-10 -mr-px -mb-px",
    invertOnHover ? "border-border hover:border-foreground hover:bg-foreground" : "border-border hover:bg-background-1",
    className,
  ]}
>
  <slot />
</div>
