---
interface Props {
  id?: string;
  class?: string;
  asideClass?: string;
  dataHomeSection?: boolean;
  dataArticlesFeatured?: boolean;
}

const {
  id,
  class: className,
  asideClass = "w-full pb-1",
  dataHomeSection = false,
  dataArticlesFeatured = false,
} = Astro.props as Props;
---

<section
  id={id}
  class:list={["relative min-h-[calc(100svh-5.5rem)]", className]}
  data-home-section={dataHomeSection ? true : undefined}
  data-articles-featured={dataArticlesFeatured ? "true" : undefined}
>
  <div class="absolute inset-0 bg-background-0"></div>

  <div class="relative px-4 md:px-8">
    <div
      class="mx-auto grid min-h-[calc(100svh-5.5rem)] w-full max-w-site gap-10 pt-8 pb-6 md:pt-12 md:pb-8 lg:grid-cols-[0.52fr_0.48fr] lg:items-end lg:gap-12 xl:gap-20"
    >
      <div class="flex min-h-[calc(100svh-11rem)] flex-col justify-between gap-10">
        <div class="max-w-2xl lg:max-w-xl">
          <slot name="headline" />
        </div>

        <div class="max-w-xl pb-2">
          <slot name="supporting" />
        </div>
      </div>

      <div class="flex items-end overflow-hidden">
        <div class={asideClass}>
          <slot name="aside" />
        </div>
      </div>
    </div>
  </div>
</section>
