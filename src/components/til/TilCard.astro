---
import { Image } from "astro:assets"
import { Icon } from "astro-icon/components"
import { Badge } from "@/components/ui/badge"
import { estimateReadTime, formatDateUppercase } from "@/lib/utils"

const { entry } = Astro.props
const readTime = estimateReadTime(entry.body || entry.data.description)
---

<a
  href={`/til/${entry.id}/`}
  class="group flex h-full min-w-0 flex-col overflow-hidden rounded-lg border border-border/80 bg-background-1 p-4 transition-colors hover:bg-background-0 md:p-5"
>
  {
    entry.data.cover && (
      <div class="mb-5 aspect-og overflow-hidden rounded-md bg-background-0" transition:name={`til-cover-${entry.id}`}>
        <Image
          src={entry.data.cover}
          alt={entry.data.coverAlt || entry.data.title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          widths={[480, 720, 960]}
          sizes="(max-width: 768px) 100vw, 32vw"
        />
      </div>
    )
  }

  <div class="flex items-center justify-between gap-4 font-mono text-xs uppercase">
    <span class="tracking-[0.24em] text-accent-1">{entry.data.topic}</span>
    <time class="text-foreground-3" datetime={entry.data.pubDatetime.toISOString()}>{formatDateUppercase(entry.data.pubDatetime)}</time>
  </div>

  <h3
    class="mt-5 font-display text-2xl leading-tight text-foreground-0 transition-colors group-hover:text-accent-1 md:text-3xl"
    transition:name={`til-title-${entry.id}`}
  >
    {entry.data.title}
  </h3>

  <p class="mt-3 text-sm leading-relaxed text-foreground-1">
    {entry.data.description}
  </p>

  {
    entry.data.tags.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {entry.data.tags.slice(0, 3).map((tag: string) => (
          <Badge variant="secondary" className="border border-border/80 bg-background-2 text-foreground-1">
            {tag}
          </Badge>
        ))}
      </div>
    )
  }

  <div class="mt-auto flex items-end justify-between gap-4 pt-7 font-display text-sm font-medium text-foreground-1 transition-colors group-hover:text-accent-1">
    <span class="font-mono text-xs text-foreground-3 uppercase">{readTime} min note</span>
    <span class="inline-flex items-center gap-2">
      Open note
      <Icon name="arrow-up-right" class="size-4" />
    </span>
  </div>
</a>
