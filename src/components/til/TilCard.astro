---
import { Icon } from "astro-icon/components";
import { formatDateUppercase } from "@/lib/utils";

interface Props {
  entry: any;
}

const { entry } = Astro.props as Props;
---

<a
  href={`/til/${entry.id}/`}
  data-note-card
  class="group flex h-80 min-w-0 flex-col bg-background-0 px-5 py-7 transition-colors duration-200 hover:bg-background-1 motion-reduce:transition-none md:px-7 md:py-8 xl:h-88"
>
  <div class="flex items-center justify-between gap-4 font-mono text-[0.625rem] tracking-[0.14em] uppercase">
    <span class="text-accent-1">{entry.data.topic}</span>
    <time class="text-foreground-3" datetime={entry.data.pubDatetime.toISOString()}>
      {formatDateUppercase(entry.data.pubDatetime)}
    </time>
  </div>

  <div class="mt-10 flex min-h-0 flex-1 flex-col">
    <h2
      class="line-clamp-3 font-display text-2xl leading-tight font-medium tracking-[-0.02em] text-foreground-0 transition-colors group-hover:text-accent-1"
      transition:name={`til-title-${entry.id}`}
    >
      {entry.data.title}
    </h2>
    <p class="mt-4 line-clamp-4 text-sm leading-6 text-foreground-2">{entry.data.description}</p>

    <div class="mt-auto flex justify-end pt-8 text-sm text-foreground-1">
      <span class="inline-flex items-center gap-2">
        Open note
        <Icon
          name="arrow-right"
          class="size-4 transition-transform group-hover:translate-x-1 motion-reduce:transition-none"
        />
      </span>
    </div>
  </div>
</a>
