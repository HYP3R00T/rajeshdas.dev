---
const { href, label, count, active = false } = Astro.props
---

<a
  href={href}
  class:list={[
    "inline-flex items-center gap-2 rounded-md border px-3 py-2 font-mono text-xs uppercase transition-colors",
    active
      ? "border-accent-1/50 bg-accent-1/10 text-accent-1"
      : "border-border/80 bg-background-1 text-foreground-2 hover:bg-background-0 hover:text-accent-1",
  ]}
>
  <span>{label}</span>
  {count !== undefined && <span class="text-foreground-3">{count}</span>}
</a>
