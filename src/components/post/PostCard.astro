---
import { Icon } from "astro-icon/components";
import { Badge } from "@/components/ui/badge";
import type { PostCardProps } from "@/lib/types";
import { estimateReadTime, formatDateUppercase } from "@/lib/utils";

const { post, index } = Astro.props as PostCardProps & { index?: number };
const readTime = estimateReadTime(post.body || post.data.description);
---

<a
  href={`/post/${post.id}/`}
  class="group flex h-full min-w-0 flex-col overflow-hidden rounded-lg border border-border/80 bg-background-1 p-5 transition-colors hover:bg-background-0 md:p-6"
>
  <div class="flex items-center justify-between gap-4 font-mono text-xs text-foreground-3 uppercase">
    {index !== undefined && <span class="text-accent-1">// {String(index + 1).padStart(2, "0")}</span>}
    <time datetime={post.data.pubDatetime.toISOString()}>{formatDateUppercase(post.data.pubDatetime)}</time>
  </div>

  <h3
    class="mt-5 font-display text-2xl leading-tight text-foreground-0 transition-colors group-hover:text-accent-1 md:text-3xl xl:text-2xl"
    transition:name={`post-title-${post.id}`}
  >
    {post.data.title}
  </h3>

  <p class="mt-3 text-sm leading-relaxed text-foreground-1">
    {post.data.description}
  </p>

  {
    post.data.tags && post.data.tags.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {post.data.tags.slice(0, 3).map((tag: string) => (
          <Badge variant="secondary" className="border border-border/80 bg-background-2 text-foreground-1">
            {tag}
          </Badge>
        ))}
      </div>
    )
  }

  <div class="mt-auto flex items-end justify-between gap-4 pt-7 font-display text-sm font-medium text-foreground-1 transition-colors group-hover:text-accent-1">
    <span class="font-mono text-xs text-foreground-3 uppercase">{readTime} min read</span>
    <span class="inline-flex items-center gap-2">
      Read article
      <Icon name="arrow-up-right" class="size-4" />
    </span>
  </div>
</a>
