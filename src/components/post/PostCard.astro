---
import { Icon } from "astro-icon/components";
import type { PostCardProps } from "@/lib/types";
import { formatDateUppercase } from "@/lib/utils";

interface Props extends PostCardProps {
  featured?: boolean;
  initiallyHidden?: boolean;
}

const { post, featured = false, initiallyHidden = false } = Astro.props as Props;
---

<a
  href={`/post/${post.id}/`}
  hidden={initiallyHidden}
  data-post-card
  data-category={post.data.category}
  data-featured-candidate={post.data.featured ? "true" : "false"}
  class:list={[
    "post-card group flex h-80 min-w-0 flex-col bg-background-0 px-5 py-7 transition-colors duration-200 motion-reduce:transition-none hover:bg-background-1 md:px-7 md:py-8 xl:h-88",
    featured && "is-featured",
  ]}
>
  <div class="flex items-center justify-between gap-4 font-mono text-[0.625rem] tracking-[0.14em] uppercase">
    <span class="post-card__featured">Featured article</span>
    <time class="post-card__date ml-auto text-foreground-3" datetime={post.data.pubDatetime.toISOString()}>
      {formatDateUppercase(post.data.pubDatetime)}
    </time>
  </div>

  <div class="mt-10 flex min-h-0 flex-1 flex-col">
    <h2
      class="post-card__title line-clamp-3 font-display text-2xl leading-tight font-medium tracking-[-0.02em] text-foreground-0 transition-colors"
      transition:name={`post-title-${post.id}`}
    >
      {post.data.title}
    </h2>
    <p class="post-card__description mt-4 line-clamp-4 text-sm leading-6 text-foreground-2">
      {post.data.description}
    </p>
    <div class="post-card__action mt-auto flex justify-end pt-8 text-sm text-foreground-1">
      <span class="inline-flex items-center gap-2">
        Read article
        <Icon name="arrow-right" class="size-4 transition-transform group-hover:translate-x-1 motion-reduce:transition-none" />
      </span>
    </div>
  </div>
</a>

<style>
  .post-card__featured {
    display: none;
  }

  .post-card:not(.is-featured):hover .post-card__title {
    color: var(--accent-1);
  }

  .post-card.is-featured,
  .post-card.is-featured:hover {
    background: var(--accent-1);
    color: var(--accent-contrast);
  }

  .post-card.is-featured .post-card__featured {
    display: inline;
    color: var(--accent-contrast);
  }

  .post-card.is-featured .post-card__date {
    color: color-mix(in srgb, var(--accent-contrast) 65%, transparent);
  }

  .post-card.is-featured .post-card__title,
  .post-card.is-featured .post-card__action {
    color: var(--accent-contrast);
  }

  .post-card.is-featured .post-card__description {
    color: color-mix(in srgb, var(--accent-contrast) 75%, transparent);
  }
</style>
