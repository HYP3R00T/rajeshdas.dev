---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import type { PostCardProps } from "@/lib/types";
import { formatDateUppercase } from "@/lib/utils";

interface Props extends PostCardProps {
  featured?: boolean;
  initiallyHidden?: boolean;
}

const { post, featured = false, initiallyHidden = false } = Astro.props as Props;
---

<a
  href={`/post/${post.id}/`}
  hidden={initiallyHidden}
  data-post-card
  data-category={post.data.category}
  data-featured-candidate={post.data.featured ? "true" : "false"}
  class:list={[
    "post-card group flex h-full min-w-0 flex-col overflow-hidden rounded-lg border border-border bg-background-0",
    featured && "is-featured",
  ]}
>
  <div class="aspect-video overflow-hidden bg-background-2">
    <Image
      src={post.data.cover}
      alt={post.data.coverAlt ?? `${post.data.title} article cover`}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.025] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
      widths={[480, 720, 960]}
      sizes="(max-width: 767px) calc(100vw - 4.5rem), (max-width: 1199px) calc(50vw - 5rem), 25rem"
    />
  </div>

  <div class="post-card__content flex min-w-0 flex-1 flex-col p-5">
    <h2
      class="post-card__title line-clamp-2 font-display text-[1.375rem] leading-tight font-medium tracking-[-0.02em] text-foreground-0 transition-colors"
      transition:name={`post-title-${post.id}`}
    >
      {post.data.title}
    </h2>
    <p class="post-card__description mt-3 line-clamp-3 text-sm leading-6 text-foreground-2">
      {post.data.description}
    </p>

    <div class="mt-auto flex items-center justify-between gap-4 pt-5">
      <div class="flex min-w-0 flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[0.625rem] tracking-[0.14em] uppercase">
        <span class="post-card__featured text-foreground-2">Featured article</span>
        <time class="post-card__date text-foreground-3" datetime={post.data.pubDatetime.toISOString()}>
          {formatDateUppercase(post.data.pubDatetime)}
        </time>
      </div>

      <span
        aria-hidden="true"
        class="post-card__action flex size-9 shrink-0 items-center justify-center rounded-md border border-border bg-background-1 text-foreground-1 transition-colors duration-150 group-hover:border-accent-1 group-hover:bg-accent-1 group-hover:text-accent-contrast"
      >
        <Icon name="arrow-right" class="size-4 transition-transform group-hover:translate-x-0.5 motion-reduce:transition-none" />
      </span>
    </div>
  </div>
</a>

<style>
  .post-card__featured {
    display: none;
  }

  .post-card:hover .post-card__title {
    color: var(--accent-1);
  }

  .post-card.is-featured {
    border-color: var(--border) !important;
    background: var(--background-0) !important;
  }

  .post-card.is-featured .post-card__featured {
    display: inline;
  }
</style>
