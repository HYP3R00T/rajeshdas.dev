---
import { Icon } from "astro-icon/components";
import { Button, buttonVariants } from "@/components/ui/button";

const { currentPage, prevUrl, nextUrl, totalPages } = Astro.props;
---

<nav aria-label="Articles pagination" class="flex justify-center pt-2">
  <div class="inline-flex items-center gap-2 rounded-lg border border-border/80 bg-background-1 p-2">
    {
      prevUrl ? (
        <a href={prevUrl} aria-label="Previous page" class={buttonVariants({ variant: "outline", size: "icon-lg" })}>
          <Icon name="arrow-left" class="size-4" />
        </a>
      ) : (
        <Button variant="outline" size="icon-lg" disabled aria-label="Previous page">
          <Icon name="arrow-left" class="size-4" />
        </Button>
      )
    }

    <div class="min-w-20 px-3 text-center font-mono text-xs tracking-[0.24em] text-foreground-2 uppercase">
      {currentPage} / {totalPages}
    </div>

    {
      nextUrl ? (
        <a href={nextUrl} aria-label="Next page" class={buttonVariants({ variant: "outline", size: "icon-lg" })}>
          <Icon name="arrow-right" class="size-4" />
        </a>
      ) : (
        <Button variant="outline" size="icon-lg" disabled aria-label="Next page">
          <Icon name="arrow-right" class="size-4" />
        </Button>
      )
    }
  </div>
</nav>
