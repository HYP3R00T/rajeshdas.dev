---
import { Icon } from "astro-icon/components";
import { buttonVariants } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import ImageCarousel from "@/components/ui/ImageCarousel.astro";
import placeholder1 from "@/assets/placeholder1.png";
import placeholder2 from "@/assets/placeholder2.png";
import { formatMonthYearRange } from "@/lib/utils";

interface Props {
  project: {
    id: string;
    data: {
      icon?: string;
      title: string;
      description: string;
      technologies: string[];
      images?: ImageMetadata[];
      imageAlt?: string;
      openSource?: boolean;
      hasPage?: boolean;
      startDate?: Date;
      endDate?: Date;
      sourceRepo?: string;
      website?: string;
    };
  };
}

const { project } = Astro.props;
const projectImages =
  project.data.images && project.data.images.length > 0 ? project.data.images : [placeholder1, placeholder2];
const projectDates = formatMonthYearRange(project.data.startDate, project.data.endDate);
const hasPage = project.data.hasPage !== false;
const showLinks = Boolean(project.data.sourceRepo || project.data.website);
---

<div class="group border-border hover:bg-card border-r border-b border-l transition-colors duration-200">
  <div class="grid items-stretch md:grid-cols-2">
    <!-- Image Section (not linked) -->
    <div class="h-full">
      <ImageCarousel images={projectImages} projectTitle={project.data.title} imageAlt={project.data.imageAlt} />
    </div>

    <!-- Content Section (linked) -->
    <div class="flex flex-col justify-between p-8 transition-colors md:p-12">
      <div>
        <div class="mb-4 flex items-center justify-between">
          <div
            class="border-border inline-flex size-10.5 shrink-0 items-center justify-center border [&>svg]:size-5.25"
          >
            <Icon name={project.data.icon || "github"} class="text-foreground size-6" />
          </div>
          {project.data.openSource && <Badge variant="outline">OPEN SOURCE</Badge>}
        </div>

        <h2
          class="group-hover:text-foreground-2 text-foreground-0 mb-4 text-2xl uppercase transition-colors md:text-3xl"
          style="font-family: 'Space Grotesk', sans-serif; font-weight: 700;"
        >
          {hasPage ? <a href={`/project/${project.id}/`}>{project.data.title}</a> : project.data.title}
        </h2>

        <p class="text-foreground-2 mb-6 text-sm leading-relaxed">
          {project.data.description}
        </p>

        {projectDates && <div class="text-foreground-2 mb-4 text-xs tracking-wide">{projectDates}</div>}

        {
          showLinks && (
            <div class="mb-4 flex flex-wrap gap-2">
              {project.data.sourceRepo && (
                <a
                  href={project.data.sourceRepo}
                  target="_blank"
                  rel="noreferrer"
                  class={buttonVariants({ variant: "outline", size: "sm" })}
                >
                  Source
                </a>
              )}
              {project.data.website && (
                <a
                  href={project.data.website}
                  target="_blank"
                  rel="noreferrer"
                  class={buttonVariants({ variant: "outline", size: "sm" })}
                >
                  Website
                </a>
              )}
            </div>
          )
        }
      </div>

      {
        project.data.technologies && project.data.technologies.length > 0 && (
          <div class="text-foreground-2 text-xs tracking-wide">{project.data.technologies.join(" • ")}</div>
        )
      }
    </div>
  </div>
</div>
