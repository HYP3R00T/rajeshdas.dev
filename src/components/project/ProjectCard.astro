---
import { Icon } from "astro-icon/components";
import IconFrame from "@/components/ui/IconFrame.astro";
import Button from "@/components/ui/Button.astro";
import { formatMonthYearRange } from "@/lib/utils";

interface Props {
  project: {
    data: {
      icon?: string;
      title: string;
      description: string;
      technologies: string[];
      startDate?: Date;
      endDate?: Date;
      sourceRepo?: string;
      website?: string;
    };
  };
  index: number;
}

const { project, index } = Astro.props;
const projectDates = formatMonthYearRange(
  project.data.startDate,
  project.data.endDate,
);
const showLinks = Boolean(project.data.sourceRepo || project.data.website);
---

<div
  class="group border-border hover:bg-background-1 bg-background-0 relative border p-6 transition-colors duration-200 hover:z-10 md:p-8"
  style="margin-right: -1px; margin-bottom: -1px;"
>
  <!-- Top row: icon + index + arrow -->
  <div class="mb-4 flex items-start justify-between">
    <div class="flex items-center gap-3">
      <IconFrame size="lg">
        <Icon
          name={project.data.icon || "github"}
          class="text-foreground-0 size-5"
        />
      </IconFrame>
      <div class="text-foreground-3 text-xs">{String(index + 1).padStart(2, "0")}</div>
    </div>
    <div
      class="border-border group-hover:bg-foreground-0 group-hover:text-background-0 group-hover:border-foreground-0 flex size-8 shrink-0 items-center justify-center border transition-colors duration-200"
    >
      <Icon name="arrow-up" class="size-4 rotate-45" />
    </div>
  </div>

  <!-- Title -->
  <h3
    class="text-foreground-0 font-display mb-2 text-lg tracking-tight uppercase md:text-xl"
  >
    {project.data.title}
  </h3>

  <!-- Description — 2 lines max -->
  <p class="text-foreground-1 mb-4 line-clamp-2 text-sm leading-relaxed">
    {project.data.description}
  </p>

  {
    projectDates && (
      <div class="text-foreground-2 mb-3 text-xs tracking-wide">
        {projectDates}
      </div>
    )
  }

  {
    showLinks && (
      <div class="mb-3 flex flex-wrap gap-2">
        {project.data.sourceRepo && (
          <Button
            as="a"
            href={project.data.sourceRepo}
            target="_blank"
            rel="noreferrer"
            variant="outline"
            size="sm"
          >
            Source
          </Button>
        )}
        {project.data.website && (
          <Button
            as="a"
            href={project.data.website}
            target="_blank"
            rel="noreferrer"
            variant="outline"
            size="sm"
          >
            Website
          </Button>
        )}
      </div>
    )
  }

  <!-- Tech stack -->
  <div class="text-foreground-3 text-xs tracking-wide">
    {project.data.technologies.join(" · ")}
  </div>
</div>
