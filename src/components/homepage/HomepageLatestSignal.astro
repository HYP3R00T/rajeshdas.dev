---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { buttonVariants } from "@/components/ui/button";
import SegmentedTabs from "@/components/common/SegmentedTabs";
import { Icon } from "astro-icon/components";
import { FileText, Play } from "lucide-react";
import { latestVideo } from "@data/homepage";

interface Props {
  latestPost: CollectionEntry<"posts">;
}

const { latestPost } = Astro.props as Props;
const videoThumb = `https://i.ytimg.com/vi/${latestVideo.id}/maxresdefault.jpg`;
const videoUrl = `https://www.youtube.com/embed/${latestVideo.id}?autoplay=1&rel=0&modestbranding=1`;
const signalTabs = [
  { value: "article", label: "Article", icon: FileText },
  { value: "video", label: "Video", icon: Play },
];
---

<section id="writing" class="px-4 py-16 md:px-8 md:py-20 lg:flex lg:min-h-[100svh] lg:items-center lg:pt-32 lg:pb-12" data-home-section>
  <div class="mx-auto grid w-full max-w-site gap-8 lg:grid-cols-[0.34fr_0.66fr] lg:items-center">
    <div class="max-w-xl">
      <p class="font-mono text-xs tracking-widest text-accent-1 uppercase">Latest signal</p>
      <h2 class="mt-4 max-w-md font-display text-4xl leading-tight tracking-tighter text-foreground-0 md:text-5xl">
        I make the thinking behind the systems visible.
      </h2>
      <p class="mt-5 max-w-md text-base leading-relaxed text-foreground-1">
        Articles and videos are where I turn hard-won engineering lessons into reusable mental models, patterns, and
        practical decisions.
      </p>
    </div>

    <div class="rounded-lg border border-border/80 bg-background-1 p-3">
      <div class="flex flex-col gap-4 border-border/80 px-1 pb-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-mono text-xs tracking-widest text-foreground-2 uppercase">Public trail</p>
          <h3 class="mt-2 font-display text-2xl leading-tight text-foreground-0">Latest artifact</h3>
        </div>
        <SegmentedTabs
          items={signalTabs}
          activeValue="article"
          ariaLabel="Latest content switcher"
          group="latest-signal"
        />
      </div>

      <div class="pt-3" data-tab-panel data-tab-group="latest-signal" data-tab-value="article">
        <div class="group block overflow-hidden rounded-md bg-background-1 transition-colors">
          <div class="relative isolate aspect-og overflow-hidden rounded-md bg-background-1">
            <Image
              src={latestPost.data.cover}
              alt={latestPost.data.coverAlt || latestPost.data.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105 group-focus-visible:scale-105"
              widths={[720, 1080]}
              sizes="(max-width: 1024px) 100vw, 720px"
            />
            <div
              class="absolute inset-0 bg-background-1/70 opacity-0 backdrop-blur-sm transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
            >
            </div>
            <div
              class="absolute inset-x-0 bottom-0 translate-y-4 p-6 opacity-0 transition duration-300 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100 md:p-8"
            >
              <h3 class="max-w-3xl font-display text-4xl leading-tight text-foreground-0 md:text-5xl">
                {latestPost.data.title}
              </h3>
            </div>
          </div>
          <div class="mt-3 px-1 pt-4 pb-1">
            <div class="flex flex-col gap-3 sm:flex-row">
              <a href={`/post/${latestPost.id}`} class={buttonVariants({ variant: "default", size: "lg" })}>
                Read Article
                <Icon name="arrow-right" class="size-4" />
              </a>
              <a href="/post" class={buttonVariants({ variant: "outline", size: "lg" })}>
                All Articles
                <Icon name="arrow-up-right" class="size-4" />
              </a>
            </div>
          </div>
        </div>
      </div>

      <div data-tab-panel data-tab-group="latest-signal" data-tab-value="video" class="hidden pt-3">
        <div class="overflow-hidden rounded-md bg-background-1 transition-colors hover:bg-background-0">
          <button
            type="button"
            class="group relative isolate block aspect-og w-full overflow-hidden rounded-md bg-background-1 text-left"
            data-video-open
            aria-label="Open latest video"
          >
            <img
              src={videoThumb}
              alt="Latest video thumbnail"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105 group-focus-visible:scale-105"
            />
            <span
              class="absolute inset-0 grid place-items-center bg-background-1/65 opacity-0 backdrop-blur-sm transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
            >
              <span
                class="rounded-md border border-border/80 bg-background-1 px-5 py-3 font-mono text-xs tracking-widest text-foreground-0 uppercase"
              >
                Play video
              </span>
            </span>
          </button>
          <div class="mt-3 px-1 pt-4 pb-1">
            <div class="flex flex-col gap-3 sm:flex-row">
              <button type="button" class={buttonVariants({ variant: "default", size: "lg" })} data-video-open>
                Open Video
              </button>
              <a
                href={latestVideo.channelUrl}
                target="_blank"
                rel="noopener noreferrer"
                class={buttonVariants({ variant: "outline", size: "lg" })}
              >
                Visit Channel
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div
  id="video-overlay"
  data-video-url={videoUrl}
  class="fixed inset-0 z-80 hidden items-center justify-center bg-background-0/90 p-4 backdrop-blur-sm"
>
  <div class="relative w-full max-w-5xl border border-border bg-background-0">
    <button
      type="button"
      id="video-overlay-close"
      class="absolute -top-14 right-0 rounded-md border border-border/80 bg-background-1 px-4 py-3 font-mono text-xs tracking-widest text-foreground-1 uppercase transition-colors hover:bg-background-2 hover:text-foreground-0"
      aria-label="Close video overlay"
    >
      Close
    </button>
    <div class="aspect-video w-full">
      <iframe
        id="video-overlay-frame"
        class="h-full w-full"
        title="Latest video"
        src=""
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen></iframe>
    </div>
  </div>
</div>

<script>
  const setupHomepageLatestSignal = () => {
    const tabs = Array.from(document.querySelectorAll('[data-tab-trigger][data-tab-group="latest-signal"]'));
    const panels = Array.from(document.querySelectorAll('[data-tab-panel][data-tab-group="latest-signal"]'));
    const overlay = document.getElementById("video-overlay");
    const frame = document.getElementById("video-overlay-frame");
    const closeButton = document.getElementById("video-overlay-close");
    const openButtons = Array.from(document.querySelectorAll("[data-video-open]"));
    const videoUrl = overlay?.getAttribute("data-video-url") || "";

    if (tabs.length && panels.length) {
      const activatePanel = (name: string) => {
        tabs.forEach((tab) => {
          const tabElement = tab as HTMLElement;
          const active = tabElement.getAttribute("data-tab-value") === name;
          tabElement.dataset.active = active ? "true" : "false";
          tabElement.setAttribute("aria-selected", active ? "true" : "false");
        });

        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.getAttribute("data-tab-value") !== name);
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const panelName = tab.getAttribute("data-tab-value");
          if (panelName) activatePanel(panelName);
        });
      });
    }

    const closeOverlay = () => {
      if (!overlay || !frame) return;
      overlay.classList.add("hidden");
      overlay.classList.remove("flex");
      frame.setAttribute("src", "");
      document.documentElement.classList.remove("overflow-hidden");
    };

    const openOverlay = () => {
      if (!overlay || !frame) return;
      overlay.classList.remove("hidden");
      overlay.classList.add("flex");
      frame.setAttribute("src", videoUrl);
      document.documentElement.classList.add("overflow-hidden");
    };

    openButtons.forEach((button) => button.addEventListener("click", openOverlay));
    closeButton?.addEventListener("click", closeOverlay);
    overlay?.addEventListener("click", (event) => {
      if (event.target === overlay) closeOverlay();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeOverlay();
    });
  };

  document.addEventListener("astro:page-load", setupHomepageLatestSignal);
</script>
