---
import { focusAreas } from "@data/homepage";
---

<section id="approach" class="py-20 md:py-32" data-home-section>
  <div class="mx-auto max-w-8xl px-4 md:px-10 lg:px-16">
    <div
      class="max-w-6xl font-display text-4xl leading-[1.05] tracking-[-0.04em] text-foreground-0 md:text-6xl lg:text-7xl"
    >
      <span class="home-reveal-line">I build systems that make engineering calmer:</span>
      <span class="home-reveal-line">fewer mystery steps, fewer tribal notes,</span>
      <span class="home-reveal-line">more repeatable paths from idea to shipped tool.</span>
    </div>

    <div class="mt-16 grid gap-10 lg:grid-cols-[0.46fr_0.54fr] lg:gap-20">
      <div class="max-w-xl text-base leading-relaxed text-foreground-1 md:text-lg">
        <p>
          This site is where I explain the thinking behind that work: articles, experiments, operating notes, and the
          learning paths that turn scattered technical knowledge into something usable.
        </p>
        <p class="mt-6">
          The deeper artifact archive lives on HYP3R00T. This place is for signal: what I am learning, what I am
          refining, and how I approach engineering problems.
        </p>
      </div>

      <div class="divide-y divide-border border-y border-border">
        {
          focusAreas.map((area) => (
            <div class="flex items-center justify-between gap-6 py-5">
              <span class="font-display text-2xl text-foreground-0">{area}</span>
              <span class="font-mono text-xl text-foreground-3">+</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .home-reveal-line {
    display: block;
    animation: home-text-reveal both linear;
    animation-timeline: view();
    animation-range: entry 5% cover 45%;
  }

  .home-reveal-line:nth-child(2) {
    animation-range: entry 12% cover 52%;
  }

  .home-reveal-line:nth-child(3) {
    animation-range: entry 20% cover 60%;
  }

  @keyframes home-text-reveal {
    0% {
      opacity: 0.18;
      filter: blur(10px);
      transform: translateY(18px);
    }

    100% {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-reveal-line {
      animation: none;
      opacity: 1;
      filter: none;
      transform: none;
    }
  }
</style>
