---
import CardGrid from "@/components/common/CardGrid.astro";
import Video from "@/components/core/Video.astro";
import { buttonVariants } from "@/components/ui/button";
---

<CardGrid>
  <!-- Column 2: Video -->
  <div>
    <!-- Header -->
    <div class="flex items-start justify-between mb-6">
      <h3 class="font-display text-foreground-1 text-sm font-bold tracking-wide uppercase">[VID] BROADCAST</h3>
      <span class="font-mono text-accent-1 text-xs">// video</span>
    </div>

    <!-- Prompt -->
    <p class="font-mono text-foreground-2 text-sm mb-8 transition-colors duration-200">&gt; connect --source youtube</p>

    <!-- Video Player -->
    <div class="mb-8">
      <Video id="v_rcTD2O-aU" />
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-between mt-auto">
      <a
        href="https://www.youtube.com/@hyperoot"
        target="_blank"
        rel="noopener noreferrer"
        class={buttonVariants({ variant: "default", size: "sm" })}
      >
        Subscribe Channel
      </a>
      <span id="video-state" class="font-mono text-foreground-2 text-[10px] tracking-wider text-right uppercase">
        STATE: IDLE
      </span>
    </div>
  </div>
</CardGrid>

<script>
  const setupVideoState = () => {
    const stateEl = document.getElementById("video-state");
    if (!stateEl) return;

    const setPlaying = () => {
      stateEl.textContent = "STATE: STREAMING";
      stateEl.classList.add("text-accent");
      stateEl.classList.remove("text-muted");
    };

    const setPaused = () => {
      stateEl.textContent = "STATE: PAUSED";
      stateEl.classList.remove("text-accent");
      stateEl.classList.add("text-muted");
    };

    const setIdle = () => {
      stateEl.textContent = "STATE: IDLE";
      stateEl.classList.remove("text-accent");
      stateEl.classList.add("text-muted");
    };

    // Listen to the global custom events dispatched by initPlyr.js
    document.addEventListener("plyr:playing", setPlaying);
    document.addEventListener("plyr:play", setPlaying);
    document.addEventListener("plyr:pause", setPaused);
    document.addEventListener("plyr:ended", setIdle);
  };

  document.addEventListener("astro:page-load", setupVideoState);
</script>
