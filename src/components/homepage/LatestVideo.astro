---
import CardGrid from "../ui/CardGrid.astro";
import Video from "@/components/core/Video.astro";
import Button from "@/components/ui/Button.astro";
---

<CardGrid>
  <!-- Column 2: Video -->
  <div>
    <!-- Header -->
    <div class="flex items-start justify-between mb-6">
      <h3
        class="font-display text-foreground-0 text-sm font-bold tracking-wide uppercase"
      >
        [VID] BROADCAST
      </h3>
      <span class="font-mono text-foreground-3 text-xs">02 // video</span>
    </div>

    <!-- Prompt -->
    <p
      class="font-mono text-foreground-2 text-sm mb-8 transition-colors duration-200"
    >
      &gt; connect --source youtube
    </p>

    <!-- Video Player -->
    <div class="mb-8">
      <Video id="v_rcTD2O-aU" />
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-between mt-auto">
      <Button
        as="a"
        href="https://www.youtube.com/@hyperoot"
        target="_blank"
        rel="noopener noreferrer"
        variant="secondary"
        size="sm"
      >
        Subscribe Channel
      </Button>
      <span
        id="video-state"
        class="font-mono text-foreground-3 text-[10px] tracking-wider text-right uppercase"
      >
        STATE: IDLE
      </span>
    </div>
  </div>
</CardGrid>

<script>
  const setupVideoState = () => {
    const playerEl = document.getElementById("player") as any;
    const stateEl = document.getElementById("video-state");

    if (!playerEl || !stateEl) return;

    const setPlaying = () => {
      stateEl.textContent = "STATE: STREAMING";
      stateEl.classList.add("text-accent");
      stateEl.classList.remove("text-foreground-3");
    };

    const setPaused = () => {
      stateEl.textContent = "STATE: PAUSED";
      stateEl.classList.remove("text-accent");
      stateEl.classList.add("text-foreground-3");
    };

    const setIdle = () => {
      stateEl.textContent = "STATE: IDLE";
      stateEl.classList.remove("text-accent");
      stateEl.classList.add("text-foreground-3");
    };

    // Wait for Plyr to be fully initialized and attached to the DOM element
    const checkInterval = setInterval(() => {
      if (playerEl.plyr) {
        clearInterval(checkInterval);
        
        // Listen directly to the Plyr instance's event emitter
        playerEl.plyr.on("playing", setPlaying);
        playerEl.plyr.on("play", setPlaying);
        playerEl.plyr.on("pause", setPaused);
        playerEl.plyr.on("ended", setIdle);
      }
    }, 100);

    // Clean up interval after 5 seconds to prevent memory leaks if Plyr fails to load
    setTimeout(() => clearInterval(checkInterval), 5000);
  };

  document.addEventListener("astro:page-load", setupVideoState);
</script>
