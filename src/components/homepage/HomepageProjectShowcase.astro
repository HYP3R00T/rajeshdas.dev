---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import placeholder1 from "@/assets/placeholder1.png";
import placeholder2 from "@/assets/placeholder2.png";
import placeholder3 from "@/assets/placeholder3.png";
import { featuredProjects } from "@data/homepage";

const projectImages = [placeholder1, placeholder2, placeholder3] as const;
---

<div
  class="relative flex min-h-[34rem] overflow-hidden bg-background-0 lg:min-h-[38rem]"
  data-project-showcase
  aria-label="Featured projects"
>
  <div class="relative z-10 flex min-w-0 flex-1 flex-col px-5 py-6 md:px-10 md:py-8 lg:p-10">
    <div class="my-auto flex min-w-0 flex-col items-center justify-center py-8 md:py-10">
      <div class="mb-5 w-full max-w-[31rem]">
        <p class="font-mono text-[0.6875rem] tracking-[0.14em] text-foreground-1 uppercase">
          Selected work
        </p>
      </div>

      <div class="grid w-full max-w-[31rem]" data-project-slides>
        {
          featuredProjects.map((project, index) => (
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-hidden={index === 0 ? "false" : "true"}
              aria-label={`View ${project.title} project`}
              tabindex={index === 0 ? 0 : -1}
              data-project-slide
              data-active={index === 0 ? "true" : "false"}
              class="group col-start-1 row-start-1 grid min-w-0 overflow-hidden rounded-lg border border-border bg-background-0/96 opacity-0 transition-opacity duration-200 data-[active=true]:z-10 data-[active=true]:opacity-100 data-[active=false]:pointer-events-none motion-reduce:transition-none"
            >
              <div class="aspect-video overflow-hidden bg-background-2">
                <Image
                  src={projectImages[index] ?? placeholder1}
                  alt={`${project.title} project preview`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.025]"
                  widths={[480, 720, 960]}
                  sizes="(max-width: 640px) calc(100vw - 5rem), 31rem"
                />
              </div>

              <div class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-end gap-5 p-5 md:p-6">
                <div class="min-w-0">
                  <p class="font-mono text-[0.625rem] tracking-[0.14em] text-accent-1 uppercase">
                    Featured project
                  </p>
                  <h2 class="mt-2 font-display text-2xl font-medium tracking-tight text-foreground-0 md:text-3xl">
                    {project.title}
                  </h2>
                  <p class="mt-3 line-clamp-2 text-sm leading-6 text-foreground-2">{project.body}</p>
                </div>
                <span
                  aria-hidden="true"
                  class="flex size-9 items-center justify-center rounded-md border border-border bg-background-1 text-foreground-1 transition-colors duration-150 group-hover:border-accent-1 group-hover:bg-accent-1 group-hover:text-accent-contrast"
                >
                  <Icon name="arrow-up-right" class="size-4" />
                </span>
              </div>
            </a>
          ))
        }
      </div>

      <div class="mt-5 flex w-full max-w-[31rem] items-center justify-between gap-5">
        <p
          class="font-mono text-[0.6875rem] tracking-[0.14em] text-foreground-3 uppercase"
          data-project-counter
        >
          01 / {String(featuredProjects.length).padStart(2, "0")}
        </p>
        <div class="flex items-center gap-2">
          <button
            type="button"
            class="flex size-9 items-center justify-center rounded-md border border-border/80 bg-background-0/90 text-foreground-1 transition-colors duration-150 hover:border-accent-1 hover:bg-accent-1 hover:text-accent-contrast focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
            aria-label="Previous featured project"
            data-project-previous
          >
            <Icon name="arrow-left" class="size-4" />
          </button>
          <button
            type="button"
            class="flex size-9 items-center justify-center rounded-md border border-border/80 bg-background-0/90 text-foreground-1 transition-colors duration-150 hover:border-accent-1 hover:bg-accent-1 hover:text-accent-contrast focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
            aria-label="Next featured project"
            data-project-next
          >
            <Icon name="arrow-right" class="size-4" />
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const setupProjectShowcases = () => {
    document.querySelectorAll<HTMLElement>("[data-project-showcase]").forEach((showcase) => {
      if (showcase.dataset.ready === "true") return;
      showcase.dataset.ready = "true";

      const slides = Array.from(showcase.querySelectorAll<HTMLElement>("[data-project-slide]"));
      const counter = showcase.querySelector<HTMLElement>("[data-project-counter]");
      const previous = showcase.querySelector<HTMLButtonElement>("[data-project-previous]");
      const next = showcase.querySelector<HTMLButtonElement>("[data-project-next]");
      if (slides.length < 2 || !previous || !next) return;

      let activeIndex = 0;
      let interval: number | undefined;
      let pointerInside = false;
      let focusInside = false;
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const showSlide = (index: number) => {
        activeIndex = (index + slides.length) % slides.length;
        slides.forEach((slide, slideIndex) => {
          const isActive = slideIndex === activeIndex;
          slide.dataset.active = String(isActive);
          slide.setAttribute("aria-hidden", String(!isActive));
          slide.tabIndex = isActive ? 0 : -1;
        });

        if (counter) {
          counter.textContent = `${String(activeIndex + 1).padStart(2, "0")} / ${String(slides.length).padStart(2, "0")}`;
        }
      };

      const stopAutoplay = () => {
        if (interval !== undefined) window.clearInterval(interval);
        interval = undefined;
      };

      const startAutoplay = () => {
        stopAutoplay();
        if (prefersReducedMotion) return;
        interval = window.setInterval(() => showSlide(activeIndex + 1), 6500);
      };

      const resumeWhenIdle = () => {
        if (!pointerInside && !focusInside) startAutoplay();
      };

      previous.addEventListener("click", () => {
        showSlide(activeIndex - 1);
        startAutoplay();
      });
      next.addEventListener("click", () => {
        showSlide(activeIndex + 1);
        startAutoplay();
      });
      showcase.addEventListener("pointerenter", () => {
        pointerInside = true;
        stopAutoplay();
      });
      showcase.addEventListener("pointerleave", () => {
        pointerInside = false;
        resumeWhenIdle();
      });
      showcase.addEventListener("focusin", () => {
        focusInside = true;
        stopAutoplay();
      });
      showcase.addEventListener("focusout", () => {
        window.requestAnimationFrame(() => {
          focusInside = showcase.contains(document.activeElement);
          resumeWhenIdle();
        });
      });
      document.addEventListener("astro:before-swap", stopAutoplay, { once: true });

      showSlide(0);
      startAutoplay();
    });
  };

  document.addEventListener("astro:page-load", setupProjectShowcases);
</script>
