---
import Section from "@/components/ui/Section.astro";
import { homepageIntent } from "@data/homepage";

const { eyebrow, headline, subheadline, routes } = homepageIntent;

const tileTone = {
  ready: "text-foreground-0",
  planned: "text-foreground-2",
} as const;
---

<Section pattern="stripe-dense">
  <div class="mx-auto w-full max-w-6xl border border-border bg-background-0">
    <div
      class="border-border flex items-center justify-between border-b px-5 py-4 md:px-7"
    >
      <p class="text-foreground-2 text-xs tracking-[0.16em] uppercase">
        {eyebrow}
      </p>
      <p
        class="text-foreground-3 hidden text-xs tracking-[0.16em] uppercase md:block"
      >
        {headline}
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4">
      {
        routes.map((route, index) => (
          <a
            href={route.href}
            class="group border-border hover:bg-background-1 block border-r border-b p-4 transition-colors duration-200 md:p-5"
          >
            <div class="text-foreground-3 mb-8 text-[10px] tracking-[0.16em] uppercase">
              {(index + 1).toString().padStart(2, "0")}
            </div>
            <h2
              class:list={[
                "font-display text-lg leading-none tracking-tight md:text-xl",
                tileTone[route.status ?? "ready"],
              ]}
            >
              {route.title}
            </h2>
            <p class="text-foreground-3 mt-3 text-[10px] tracking-[0.16em] uppercase">
              {route.status === "planned" ? "planned" : "open"}
            </p>
          </a>
        ))
      }

      <div class="border-border text-foreground-2 border-r border-b p-4 md:p-5">
        <p class="text-xs tracking-[0.16em] uppercase">Decision First</p>
      </div>
      <div class="border-border text-foreground-2 border-r border-b p-4 md:p-5">
        <p class="text-xs tracking-[0.16em] uppercase">Less Noise</p>
      </div>
      <div class="border-border text-foreground-2 border-r border-b p-4 md:p-5">
        <p class="text-xs tracking-[0.16em] uppercase">Clear Paths</p>
      </div>
      <div class="border-border text-foreground-2 border-b p-4 md:p-5">
        <p class="text-xs tracking-[0.16em] uppercase">Real Outcomes</p>
      </div>
    </div>

    <div class="border-border border-t px-5 py-4 md:px-7">
      <p class="text-foreground-3 text-xs tracking-[0.16em] uppercase">
        {subheadline}
      </p>
    </div>
  </div>
</Section>
