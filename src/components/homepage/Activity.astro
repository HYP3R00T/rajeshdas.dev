---
import LatestBlog from "./LatestBlog.astro";
import LatestVideo from "./LatestVideo.astro";
import LatestActivity from "./LatestActivity.astro";
---

<section class="relative px-4 md:px-12 py-24 md:py-32" id="latest-activity">
  <div class="mx-auto w-full max-w-7xl">
    <!-- Section label -->
    <p
      class="font-mono text-foreground-3 text-xs tracking-widest uppercase mb-4"
    >
      // latest_activity
    </p>

    <!-- Card grid -->
    <div class="activity-grid grid grid-cols-1 lg:grid-cols-3 lg:items-start">
      <div class="lg:col-span-2 flex flex-col">
        <LatestVideo />
        <LatestBlog />
      </div>
      <LatestActivity />
    </div>
  </div>
</section>
