---
import SiteSection from "@/components/core/SiteSection.astro";
import { homepageMetrics } from "@data/homepage";
---

<SiteSection id="proof" data-home-section aria-labelledby="proof-title">
  <header class="site-section-heading flex min-h-72 flex-col items-center justify-center px-5 py-16 text-center md:min-h-80 md:px-10 md:py-20">
    <p class="font-mono text-[0.6875rem] tracking-[0.14em] text-accent-1 uppercase">Measured proof</p>
    <h2
      id="proof-title"
      class="mt-5 max-w-2xl text-balance font-display text-4xl leading-[1.05] font-medium tracking-[-0.03em] text-foreground-0 md:text-5xl"
    >
      Evidence behind the systems.
    </h2>
  </header>

  <div class="grid md:grid-cols-2 xl:grid-cols-4">
    {
      homepageMetrics.map((metric, index) => (
        <article
          class:list={[
            "flex min-h-56 flex-col border-border px-5 py-8 transition-colors duration-200 hover:bg-background-1 motion-reduce:transition-none md:min-h-64 md:odd:border-r md:px-8 md:py-9 xl:border-t-0 xl:border-r xl:px-9 xl:last:border-r-0",
            index > 0 && "border-t",
            index === 1 && "md:border-t-0",
          ]}
        >
          <div>
            <p class="font-display text-5xl leading-none font-medium tracking-[-0.04em] text-foreground-0 lg:text-6xl">
              {metric.value}
            </p>
            <p class="mt-3 font-mono text-[0.6875rem] tracking-[0.14em] text-accent-1 uppercase">{metric.unit}</p>
          </div>

          <h3 class="mt-auto max-w-xs pt-10 font-display text-xl leading-tight font-medium text-foreground-0 md:text-2xl">
            {metric.label}
          </h3>
        </article>
      ))
    }
  </div>
</SiteSection>
