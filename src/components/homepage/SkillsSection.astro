---
// Skills Section Component
// Displays categorized tech stack in a grid with icons and items
import Section from "@/components/ui/Section.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";
import Skill from "@/components/homepage/Skill.astro";
import { skills } from "@data/homepage";
---

<Section>
  <SectionHeader
    badge="Tech Stack"
    description="Technologies and tools I use to build reliable, scalable infrastructure"
  >
    <div>EXPERTISE</div>
  </SectionHeader>

  <div class="grid md:grid-cols-2 lg:grid-cols-4">
    {
      skills.map((skill) => (
        <Skill
          id={skill.id}
          title={skill.title}
          icon={skill.icon}
          items={skill.items}
        />
      ))
    }
  </div>
</Section>
