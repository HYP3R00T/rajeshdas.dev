---
// Skills Section Component
// Displays categorized tech stack in a grid with icons and items
import Badge from "@/components/ui/Badge.astro";
import Skill from "@/components/homepage/Skill.astro";
import { skills } from "@data/homepage";
---

<section class="relative px-6 py-24 md:px-12 md:py-32">
  <div class="mx-auto w-full max-w-7xl">
    <div class="mb-12">
      <Badge variant="outline">Tech Stack</Badge>
      <h1 class="text-section-heading my-8">
        <div>EXPERTISE</div>
      </h1>
      <p
        class="text-foreground-1 max-w-2xl text-base leading-relaxed md:text-lg"
      >
        Technologies and tools I use to build reliable, scalable infrastructure
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4">
      {
        skills.map((skill) => (
          <Skill
            id={skill.id}
            title={skill.title}
            icon={skill.icon}
            items={skill.items}
          />
        ))
      }
    </div>
  </div>
</section>
