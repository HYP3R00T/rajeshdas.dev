---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import CardGrid from "../ui/CardGrid.astro";
import Button from "@/components/ui/Button.astro";
import { getSortedPosts } from "@/lib/utils";

const allPosts = await getCollection("posts");
const sorted = getSortedPosts(allPosts);
const latest = sorted[0];
---

{
  latest && (
    <CardGrid>
      <!-- Header -->
      <div class="flex items-start justify-between mb-4">
        <h3 class="font-display text-foreground-0 text-sm font-bold tracking-wide uppercase">
          [TXT] LATEST_ENTRY
        </h3>
        <span class="font-mono text-foreground-3 text-xs">// note</span>
      </div>

      <!-- Prompt -->
      <p class="font-mono text-foreground-2 text-sm mb-4 transition-colors duration-200">
        &gt; fetch ./field_notes/latest.md
      </p>

      <!-- Cover image with overlay -->
      <a
        href={`/post/${latest.id}`}
        class="group/img block relative overflow-hidden mb-4"
        aria-label={`Read: ${latest.data.title}`}
      >
        <div class="aspect-video overflow-hidden">
          <Image
            src={latest.data.cover}
            alt={latest.data.coverAlt || latest.data.title}
            class="w-full h-full object-cover scale-105 blur-[2px] brightness-40 transition-all duration-500 group-hover/img:brightness-50 group-hover/img:blur-[3px]"
            widths={[640, 960]}
            sizes="(max-width: 768px) 100vw, 640px"
          />
        </div>

        <!-- Text overlay -->
        <div class="absolute inset-0 flex flex-col justify-end p-4">
          {latest.data.tags.length > 0 && (
            <span class="font-mono text-accent text-[10px] tracking-widest uppercase mb-2">
              {latest.data.tags[0]}
            </span>
          )}
          <h4 class="font-display text-foreground-0 text-3xl font-bold leading-snug mb-1 drop-shadow">
            {latest.data.title}
          </h4>
          <p class="font-sans text-foreground-1 text-base leading-relaxed line-clamp-2 drop-shadow">
            {latest.data.description}
          </p>
        </div>
      </a>

      <!-- Footer -->
      <div class="flex items-center justify-between">
        <Button
          as="a"
          href="/post"
          variant="secondary"
          size="sm"
        >
          All Posts
        </Button>

        <span
          id="blog-time-ago"
          class="font-mono text-foreground-3 text-[10px] tracking-wider uppercase"
          data-date={latest.data.pubDatetime.toISOString()}
        >
          PUBLISHED
        </span>
      </div>
    </CardGrid>
  )
}

<script>
  const setupTimeAgo = () => {
    const el = document.getElementById("blog-time-ago");
    if (!el) return;

    const iso = el.dataset.date;
    if (!iso) return;

    const pub = new Date(iso).getTime();

    const format = () => {
      const diffMs = Date.now() - pub;
      const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
      const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
      const diffMins = Math.floor(diffMs / (1000 * 60));

      let label: string;
      if (diffMins < 60) {
        label = diffMins <= 1 ? "JUST NOW" : `${diffMins}M AGO`;
      } else if (diffHours < 24) {
        label = `${diffHours}H AGO`;
      } else if (diffDays === 1) {
        label = "YESTERDAY";
      } else if (diffDays < 30) {
        label = `${diffDays}D AGO`;
      } else if (diffDays < 365) {
        const months = Math.floor(diffDays / 30);
        label = `${months}MO AGO`;
      } else {
        const years = Math.floor(diffDays / 365);
        label = `${years}Y AGO`;
      }

      el.textContent = `LAST POST: ${label}`;
    };

    format();
    // Update every minute so it stays live
    setInterval(format, 60_000);
  };

  document.addEventListener("astro:page-load", setupTimeAgo);
</script>
