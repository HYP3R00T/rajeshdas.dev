---
import { Icon } from "astro-icon/components";
import CardGrid from "@/components/ui/CardGrid.astro";
import Button from "@/components/ui/Button.astro";
import { pinnedProjects } from "@data/pinned-projects";
import activityData from "@data/github-activity.json";
import statsData from "@data/github-stats.json";
import {
  buildContribGrid,
  contribIntensity,
  mergeProjectStats,
  type RepoStats,
} from "@/lib/github";

const contributions = activityData.contributions ?? [];
const { grid, rowLabels, totalContribs, maxCount } = buildContribGrid(contributions);
const hasData = grid.length > 0;

const repoStatsMap = statsData.repos as Record<string, RepoStats>;
const projectsWithStats = mergeProjectStats(pinnedProjects, repoStatsMap);
---

<CardGrid class="h-full flex flex-col">
  <!-- Header -->
  <div class="flex items-start justify-between mb-4">
    <h3
      class="font-display text-foreground-0 text-sm font-bold tracking-wide uppercase"
    >
      [SYS] ACTIVITY
    </h3>
    <span class="font-mono text-foreground-3 text-xs">03 // build</span>
  </div>

  <!-- Prompt -->
  <p class="font-mono text-foreground-2 text-sm mb-4">
    &gt; gh contributions --weeks 16
  </p>

  <!-- Heatmap -->
  {
    hasData ? (
      <div class="mb-4 flex-shrink-0">
        <div class="flex mb-1 pl-9">
          <div class="grid grid-cols-7 gap-1 flex-1">
            {["M", "T", "W", "T", "F", "S", "S"].map((d) => (
              <div class="font-mono text-foreground-3 text-xs leading-none text-center">
                {d}
              </div>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-1">
          {grid.map((week, rowIdx) => (
            <div class="flex items-center gap-1">
              <div class="w-8 shrink-0 font-mono text-foreground-3 text-xs leading-none text-right">
                {rowLabels[rowIdx] ?? ""}
              </div>
              <div class="grid grid-cols-7 gap-1 flex-1">
                {week.map((day) => {
                  const level = day ? contribIntensity(day.count, maxCount) : 0;
                  const title = day
                    ? `${day.count} contribution${day.count !== 1 ? "s" : ""} on ${day.date}`
                    : "";
                  return (
                    <div
                      class="contrib-cell aspect-square w-full"
                      data-level={level}
                      title={title}
                      aria-label={title || "No contributions"}
                    />
                  );
                })}
              </div>
            </div>
          ))}
        </div>

        <!-- Legend + summary -->
        <div class="flex items-center justify-between mt-2">
          <p class="font-mono text-foreground-3 text-[10px] tracking-wider">
            {totalContribs} CONTRIB / 16W
          </p>
          <div class="flex items-center gap-1">
            <span class="font-mono text-foreground-3 text-[8px]">less</span>
            {[0, 1, 2, 3, 4].map((level) => (
              <div class="contrib-cell w-2 h-2" data-level={level} />
            ))}
            <span class="font-mono text-foreground-3 text-[8px]">more</span>
          </div>
        </div>
      </div>
    ) : (
      <div class="mb-4 border border-border p-3 flex-shrink-0">
        <p class="font-mono text-foreground-3 text-xs text-center">
          // run: uv run fetch-github-activity
        </p>
      </div>
    )
  }

  <div class="flex flex-col gap-3">
    {
      projectsWithStats.map((project) => (
        <a
          href={project.href}
          target={project.external ? "_blank" : undefined}
          rel={project.external ? "noopener noreferrer" : undefined}
          class="group flex items-start gap-3 py-2 border-t border-border transition-colors hover:bg-background-2 -mx-6 px-6"
        >
          <div class="mt-0.5 shrink-0 text-foreground-3 transition-colors">
            <Icon name={project.icon} class="w-4 h-4" />
          </div>
          <div class="min-w-0 flex-1">
            <div class="flex items-center justify-between gap-2 mb-0.5">
              <span class="font-mono text-foreground-0 text-sm font-medium transition-colors truncate">
                {project.title}
              </span>
              <div class="flex items-center gap-1 shrink-0 text-foreground-3">
                <Icon name="zap" class="w-3 h-3" />
                <span class="font-mono text-xs">{project.stars}</span>
              </div>
            </div>
            <p class="font-sans text-foreground-2 text-xs leading-snug line-clamp-1">
              {project.description}
            </p>
          </div>
        </a>
      ))
    }
  </div>

  <!-- Footer -->
  <div class="flex items-center justify-between mt-auto">
    <Button
      as="a"
      href="https://github.com/HYP3R00T"
      target="_blank"
      rel="noopener noreferrer"
      variant="secondary"
      size="sm"
    >
      github.com/HYP3R00T
    </Button>
    <Icon name="github" class="w-4 h-4 text-foreground-3" />
  </div>
</CardGrid>

<style>
  /* Contribution cell colors using CSS variables from the theme */
  .contrib-cell[data-level="0"] {
    background-color: var(--background-2);
  }
  .contrib-cell[data-level="1"] {
    background-color: color-mix(in hsl, var(--accent) 20%, transparent);
  }
  .contrib-cell[data-level="2"] {
    background-color: color-mix(in hsl, var(--accent) 40%, transparent);
  }
  .contrib-cell[data-level="3"] {
    background-color: color-mix(in hsl, var(--accent) 65%, transparent);
  }
  .contrib-cell[data-level="4"] {
    background-color: var(--accent);
  }
</style>
