---
import CardGrid from "../ui/CardGrid.astro";
---

<CardGrid class="h-full">
  <!-- Column 3: Project -->
  <a href="/project" class="flex flex-col h-full">
    <!-- Header -->
    <div class="flex items-start justify-between mb-6">
      <h3
        class="font-display text-foreground-0 text-sm font-bold tracking-wide uppercase"
      >
        [EXE] ACTIVE_SYSTEM
      </h3>
      <span class="font-mono text-foreground-3 text-xs">03 // build</span>
    </div>

    <!-- Prompt -->
    <p
      class="font-mono text-foreground-2 text-sm mb-8 transition-colors duration-200"
    >
      &gt; git status --short
    </p>

    <!-- Divider -->
    <div class="border-border border-t mb-6"></div>

    <!-- Content -->
    <h4 class="font-display text-foreground-0 text-base font-bold mb-2">
      Infrastructure Orchestration
    </h4>
    <p class="font-sans text-foreground-2 text-sm leading-relaxed mb-8">
      Refactoring infrastructure orchestration: solving the ROCm dependency
      conflict.
    </p>

    <!-- Footer -->
    <div class="flex items-end justify-between mt-auto">
      <span class="font-mono text-foreground-3 text-[10px] tracking-wider">
        Rajesh.sys
      </span>
      <span
        class="font-mono text-foreground-3 text-[10px] tracking-wider text-right"
      >
        BRANCH: main | LAST_COMMIT: 4h ago
      </span>
    </div>
  </a>
</CardGrid>
