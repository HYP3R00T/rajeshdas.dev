---
import { Icon } from "astro-icon/components";
import SiteSection from "@/components/core/SiteSection.astro";
import HomepageProjectShowcase from "@/components/homepage/HomepageProjectShowcase.astro";
import { buttonVariants } from "@/components/ui/button";
import { cn } from "@/lib/utils";
---

<SiteSection id="hero" data-home-section aria-labelledby="homepage-title" frameClass="grid lg:grid-cols-2">
  <div class="flex min-w-0 items-center px-5 py-14 md:px-10 md:py-18 lg:min-h-[38rem] lg:p-15">
    <div class="max-w-xl">
      <p class="flex items-center gap-2.5 font-mono text-[0.6875rem] tracking-[0.14em] text-foreground-1 uppercase">
        <span aria-hidden="true" class="size-1.5 rounded-full bg-accent-1"></span>
        Engineering by design
      </p>

      <h1
        id="homepage-title"
        class="mt-8 text-balance font-display text-[clamp(3rem,4.2vw,4rem)] leading-[0.98] font-medium tracking-[-0.035em] text-foreground-0"
      >
        I turn messy workflows into systems that last.
      </h1>

      <p class="mt-7 max-w-lg text-base leading-7 text-foreground-2 md:text-lg md:leading-8">
        Practical DevOps, automation, and AI workflows that stay understandable, repeatable, and cost-effective.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="/contact"
          class={cn(
            buttonVariants({ variant: "default", size: "lg" }),
            "bg-accent-1 px-5 text-accent-contrast hover:bg-accent-2",
          )}
        >
          Let&apos;s work together
          <Icon name="arrow-right" class="size-4" />
        </a>
        <a
          href="https://hyperoot.dev"
          target="_blank"
          rel="noopener noreferrer"
          class={cn(buttonVariants({ variant: "outline", size: "lg" }), "px-5")}
        >
          View all work
          <Icon name="arrow-up-right" class="size-4" />
        </a>
      </div>
    </div>
  </div>

  <div class="min-w-0 lg:min-h-[38rem]">
    <HomepageProjectShowcase />
  </div>
</SiteSection>
