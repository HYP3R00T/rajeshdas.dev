---
import { buttonVariants } from "@/components/ui/button";
import { Icon } from "astro-icon/components";
import { featuredProjects } from "@data/homepage";
---

<section
  id="hero"
  class="relative min-h-svh border-b border-border"
  data-home-section
>
  <div class="absolute inset-0 bg-background-0"></div>

  <div
    class="relative mx-auto flex min-h-svh max-w-8xl flex-col justify-between gap-8 px-4 py-8 md:px-10 lg:px-16"
  >
    <div
      class="max-w-2xl pb-16 sm:pb-24 lg:max-w-md lg:pb-0 xl:max-w-xl"
    >
      <h1
        class="font-display text-5xl leading-none font-semibold tracking-tighter text-foreground-0 sm:text-6xl lg:text-5xl xl:text-6xl"
      >
        DevOps engineer + automation builder based in Kolkata, India.
      </h1>
    </div>

    <div
      class="grid gap-8 pb-2 lg:grid-cols-2 lg:items-end lg:gap-12 xl:gap-20"
    >
      <div class="max-w-xl">
        <p class="font-mono text-xs tracking-widest text-foreground-2 uppercase">
          <span>Remote</span>
          <span class="text-foreground-3"> / </span>
          <span data-local-time>Asia/Kolkata</span>
        </p>
        <p
          class="mt-4 max-w-lg text-base leading-relaxed text-foreground-1 md:text-lg"
        >
          I build reproducible developer environments, automation workflows, and technical learning systems for teams
          who want less setup friction and clearer engineering paths.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a href="/contact" class={buttonVariants({ variant: "default", size: "lg" })}>
            Let&apos;s Work Together
            <Icon name="arrow-right" class="size-4" />
          </a>
          <a href="https://hyperoot.dev" class={buttonVariants({ variant: "outline", size: "lg" })}>
            View All Work
            <Icon name="arrow-up-right" class="size-4" />
          </a>
        </div>
      </div>

      <div
        class="grid items-end gap-4 sm:grid-cols-2 lg:gap-6"
      >
        {
          featuredProjects.map((project) => (
            <a
              href={project.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group min-w-0 border border-border bg-background-0 transition-colors hover:border-accent-1 hover:bg-background-1"
            >
              <div class="relative aspect-video overflow-hidden border-b border-border bg-background-1">
                <div class="absolute inset-0 opacity-70 bg-[linear-gradient(90deg,color-mix(in_oklab,var(--border)_80%,transparent)_1px,transparent_1px),linear-gradient(color-mix(in_oklab,var(--border)_80%,transparent)_1px,transparent_1px),linear-gradient(135deg,color-mix(in_oklab,var(--accent-1)_18%,transparent),transparent_42%)] bg-size-[26px_26px,26px_26px,100%_100%]" />
                <div class="absolute left-5 top-5 font-mono text-xs tracking-widest text-accent-1 uppercase">
                  {project.signal}
                </div>
                <div class="absolute bottom-5 right-5 h-14 w-20 border border-border bg-background-0 transition-transform duration-300 group-hover:-translate-y-1 group-hover:translate-x-1">
                  <div class="h-full w-full bg-linear-to-br from-accent-1/35 via-transparent to-foreground-0/10" />
                </div>
              </div>
              <div class="p-4 xl:p-5">
                <div class="font-mono text-xs tracking-widest text-foreground-2 uppercase">{project.label}</div>
                <h2 class="mt-3 font-display text-xl leading-tight text-foreground-0 xl:text-2xl">
                  {project.title}
                </h2>
                <p class="mt-3 text-sm leading-relaxed text-foreground-1">
                  {project.body}
                </p>
                <div class="mt-5 border-t border-border pt-4 font-mono text-xs tracking-widest text-foreground-1 uppercase transition-colors group-hover:text-accent-1">
                  <span class="inline-flex items-center gap-2">
                    View case study
                    <Icon name="arrow-up-right" class="size-4" />
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const setupLocalTime = () => {
    const target = document.querySelector("[data-local-time]");
    if (!target) return;

    const update = () => {
      const time = new Intl.DateTimeFormat("en-US", {
        timeZone: "Asia/Kolkata",
        hour: "numeric",
        minute: "2-digit",
        second: "2-digit",
        hour12: true,
      }).format(new Date());

      target.textContent = `Now, ${time} IST`;
    };

    update();
    const interval = window.setInterval(update, 1000);
    document.addEventListener("astro:before-swap", () => window.clearInterval(interval), { once: true });
  };

  document.addEventListener("astro:page-load", setupLocalTime);
</script>
