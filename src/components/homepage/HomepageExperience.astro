---
import { getCollection } from "astro:content";
import HomepageHero from "@/components/homepage/HomepageHero.astro";
import HomepageMetrics from "@/components/homepage/HomepageMetrics.astro";
import HomepageLatestSignal from "@/components/homepage/HomepageLatestSignal.astro";
import { getSortedPosts } from "@/lib/utils";

const allPosts = await getCollection("posts");
const sortedPosts = getSortedPosts(allPosts);
const latestPost = sortedPosts[0];
---

<div class="homepage homepage-snap overflow-hidden">
  <HomepageHero />
  <HomepageMetrics />
  {latestPost && <HomepageLatestSignal latestPost={latestPost} />}
</div>

<style is:global>
  @media (min-width: 1024px) and (prefers-reduced-motion: no-preference) {
    html:has(.homepage-snap) {
      scroll-behavior: smooth;
      scroll-padding-top: 0;
    }
  }
</style>

<script>
  declare global {
    interface Window {
      __homepageSectionSnapCleanup?: () => void;
    }
  }

  const setupHomepageSectionSnap = () => {
    window.__homepageSectionSnapCleanup?.();

    const root = document.querySelector(".homepage-snap");
    const canSnap = window.matchMedia("(min-width: 1024px) and (prefers-reduced-motion: no-preference)");

    if (!root || !canSnap.matches) return;

    const sections = Array.from(root.querySelectorAll<HTMLElement>("[data-home-section]"));
    const heroSection = sections[0];
    const nextSection = sections[1];

    if (!heroSection || !nextSection) return;

    let isSnapping = false;
    let releaseTimer = 0;

    const sectionBounds = (section: HTMLElement) => {
      const top = Math.max(0, window.scrollY + section.getBoundingClientRect().top);
      return {
        top,
        bottom: top + section.offsetHeight,
      };
    };

    const scrollToSection = (section: HTMLElement, topOverride?: number) => {
      isSnapping = true;
      window.clearTimeout(releaseTimer);

      const top = topOverride ?? Math.max(0, window.scrollY + section.getBoundingClientRect().top);
      window.scrollTo({ top, behavior: "smooth" });

      releaseTimer = window.setTimeout(() => {
        isSnapping = false;
      }, 900);
    };

    const onWheel = (event: WheelEvent) => {
      const target = event.target as HTMLElement | null;

      if (event.ctrlKey || event.metaKey || event.altKey) return;
      if (Math.abs(event.deltaX) > Math.abs(event.deltaY)) return;
      if (Math.abs(event.deltaY) < 12) return;
      if (target?.closest("#video-overlay")) return;
      if (isSnapping) {
        event.preventDefault();
        return;
      }

      const direction = event.deltaY > 0 ? 1 : -1;
      const threshold = 24;
      const heroBounds = sectionBounds(heroSection);
      const nextBounds = sectionBounds(nextSection);
      const viewportBottom = window.scrollY + window.innerHeight;
      const nearHeroBottom = viewportBottom >= heroBounds.bottom - threshold;
      const nearNextTop = window.scrollY <= nextBounds.top + threshold;
      const beforeNextSection = window.scrollY < nextBounds.top - threshold;
      const aroundNextStart = window.scrollY >= nextBounds.top - 120 && window.scrollY <= nextBounds.top + 120;

      if (direction > 0 && beforeNextSection && nearHeroBottom) {
        event.preventDefault();
        scrollToSection(nextSection);
        return;
      }

      if (direction < 0 && aroundNextStart && nearNextTop) {
        event.preventDefault();
        scrollToSection(heroSection, 0);
      }
    };

    const onMediaChange = () => {
      if (!canSnap.matches) window.__homepageSectionSnapCleanup?.();
    };

    window.addEventListener("wheel", onWheel, { passive: false });
    canSnap.addEventListener("change", onMediaChange);

    window.__homepageSectionSnapCleanup = () => {
      window.removeEventListener("wheel", onWheel);
      canSnap.removeEventListener("change", onMediaChange);
      window.clearTimeout(releaseTimer);
      isSnapping = false;
      window.__homepageSectionSnapCleanup = undefined;
    };
  };

  document.addEventListener("astro:page-load", setupHomepageSectionSnap);
</script>
