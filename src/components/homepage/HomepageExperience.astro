---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { buttonVariants } from "@/components/ui/button";
import { Icon } from "astro-icon/components";

interface Props {
  latestPost: CollectionEntry<"posts">;
}

const { latestPost } = Astro.props as Props;

const featuredProjects = [
  {
    title: "Dotfiles",
    label: "Reproducible environments",
    body: "A one-command machine setup workflow for devcontainers, WSL, and cloud VMs.",
    href: "https://dotfiles.hyperoot.dev/",
    signal: "setup -> repeatable",
  },
  {
    title: "Celestial Docs",
    label: "Documentation systems",
    body: "A static docs system built for customization, free hosting, and source-level ownership.",
    href: "https://celestialdocs.hyperoot.dev/",
    signal: "docs -> portable",
  },
];

const focusAreas = ["Developer environments", "Automation workflows", "Python tooling", "Technical writing"];

const videoId = "v_rcTD2O-aU";
const videoThumb = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
const videoUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&modestbranding=1`;
---

<div class="homepage overflow-hidden">
  <section id="hero" class="home-hero relative min-h-[calc(100svh-6rem)] border-b border-border" data-home-section>
    <div class="absolute inset-0 bg-background-0"></div>

    <div
      class="home-hero-shell relative mx-auto grid min-h-[calc(100svh-6rem)] max-w-8xl grid-rows-[auto_1fr_auto] px-4 py-8 md:px-10 lg:px-16"
    >
      <div class="home-hero-heading max-w-3xl">
        <h1 class="font-display leading-[1.02] font-semibold tracking-[-0.05em] text-foreground-0">
          DevOps engineer + automation builder based in Kolkata, India.
        </h1>
      </div>

      <div aria-hidden="true"></div>

      <div class="home-hero-bottom grid gap-10 pb-2 lg:grid-cols-[0.46fr_0.54fr] lg:items-end lg:gap-20">
        <div class="home-hero-intro max-w-xl">
          <p class="font-mono text-xs tracking-[0.18em] text-foreground-2 uppercase">
            <span>Remote</span>
            <span class="text-foreground-3"> / </span>
            <span data-local-time>Asia/Kolkata</span>
          </p>
          <p class="mt-4 text-base leading-relaxed text-foreground-1 md:text-lg">
            I build reproducible developer environments, automation workflows, and technical learning systems for teams
            who want less setup friction and clearer engineering paths.
          </p>
          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a href="/contact" class={buttonVariants({ variant: "default", size: "lg" })}>
              Let&apos;s Work Together
              <Icon name="arrow-right" class="size-4" />
            </a>
            <a href="https://hyperoot.dev" class={buttonVariants({ variant: "outline", size: "lg" })}>
              View All Work
              <Icon name="arrow-up-right" class="size-4" />
            </a>
          </div>
        </div>

        <div class="home-hero-cases grid gap-6 md:grid-cols-2">
          {
            featuredProjects.map((project) => (
              <a
                href={project.href}
                target="_blank"
                rel="noopener noreferrer"
                class="home-case-card group border border-border bg-background-0 transition-colors hover:border-accent-1 hover:bg-background-1"
              >
                <div class="home-case-visual relative overflow-hidden border-b border-border bg-background-1">
                  <div class="absolute inset-0 home-project-field opacity-70"></div>
                  <div class="absolute left-5 top-5 font-mono text-[10px] tracking-[0.22em] text-accent-1 uppercase">
                    {project.signal}
                  </div>
                  <div class="absolute bottom-5 right-5 h-14 w-20 border border-border bg-background-0 transition-transform duration-300 group-hover:-translate-y-1 group-hover:translate-x-1">
                    <div class="h-full w-full bg-linear-to-br from-accent-1/35 via-transparent to-foreground-0/10"></div>
                  </div>
                </div>
                <div class="home-case-content p-5">
                  <div class="font-mono text-[10px] tracking-[0.2em] text-foreground-2 uppercase">{project.label}</div>
                  <h2 class="home-case-title mt-3 font-display leading-tight text-foreground-0">{project.title}</h2>
                  <p class="home-case-body mt-3 text-sm leading-relaxed text-foreground-1">{project.body}</p>
                  <div class="mt-5 border-t border-border pt-4 font-mono text-[11px] tracking-[0.18em] text-foreground-1 uppercase transition-colors group-hover:text-accent-1">
                    <span class="inline-flex items-center gap-2">
                      View case study
                      <Icon name="arrow-up-right" class="size-4" />
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="approach" class="py-20 md:py-32" data-home-section>
    <div class="mx-auto max-w-8xl px-4 md:px-10 lg:px-16">
      <div class="max-w-6xl font-display text-4xl leading-[1.05] tracking-[-0.04em] text-foreground-0 md:text-6xl lg:text-7xl">
        <span class="home-reveal-line">I build systems that make engineering calmer:</span>
        <span class="home-reveal-line">fewer mystery steps, fewer tribal notes,</span>
        <span class="home-reveal-line">more repeatable paths from idea to shipped tool.</span>
      </div>

      <div class="mt-16 grid gap-10 lg:grid-cols-[0.46fr_0.54fr] lg:gap-20">
        <div class="max-w-xl text-base leading-relaxed text-foreground-1 md:text-lg">
          <p>
            This site is where I explain the thinking behind that work: articles, experiments, operating notes, and the
            learning paths that turn scattered technical knowledge into something usable.
          </p>
          <p class="mt-6">
            The deeper artifact archive lives on HYP3R00T. This place is for signal: what I am learning, what I am
            refining, and how I approach engineering problems.
          </p>
        </div>

        <div class="divide-y divide-border border-y border-border">
          {
            focusAreas.map((area) => (
              <div class="flex items-center justify-between gap-6 py-5">
                <span class="font-display text-2xl text-foreground-0">{area}</span>
                <span class="font-mono text-xl text-foreground-3">+</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="writing" class="border-t border-border py-16 md:py-24" data-home-section>
    <div class="mx-auto grid max-w-8xl gap-10 px-4 md:px-10 lg:grid-cols-[0.34fr_0.66fr] lg:px-16">
      <div>
        <p class="font-mono text-xs tracking-[0.22em] text-accent-1 uppercase">Live notes</p>
        <h2 class="mt-4 max-w-md font-display text-4xl leading-tight tracking-[-0.03em] text-foreground-0 md:text-5xl">
          Fresh from the lab, before it becomes a case study.
        </h2>
      </div>

      <div class="flex flex-col border border-border bg-background-0">
        <div
          class="grid border-b border-border bg-background-1 sm:grid-cols-2"
          role="tablist"
          aria-label="Latest content switcher"
        >
          <button
            type="button"
            class="home-tab group border-b border-border px-5 py-3 text-left transition-colors data-[active=true]:bg-background-0 sm:border-r sm:border-b-0"
            data-home-tab
            data-panel="article"
            data-active="true"
            role="tab"
            aria-selected="true"
          >
            <span class="flex items-center justify-between gap-4">
              <span class="font-mono text-[11px] tracking-[0.2em] text-foreground-2 uppercase">Article</span>
              <span class="h-2 w-2 border border-foreground-3 group-data-[active=true]:border-accent-1 group-data-[active=true]:bg-accent-1"></span>
            </span>
          </button>
          <button
            type="button"
            class="home-tab group px-5 py-3 text-left transition-colors data-[active=true]:bg-background-0"
            data-home-tab
            data-panel="video"
            role="tab"
            aria-selected="false"
          >
            <span class="flex items-center justify-between gap-4">
              <span class="font-mono text-[11px] tracking-[0.2em] text-foreground-2 uppercase">Video</span>
              <span class="h-2 w-2 border border-foreground-3 group-data-[active=true]:border-accent-1 group-data-[active=true]:bg-accent-1"></span>
            </span>
          </button>
        </div>

        <div data-home-panel="article">
          <a href={`/post/${latestPost.id}`} class="group block overflow-hidden bg-background-0 transition-colors">
            <div class="relative aspect-og overflow-hidden bg-background-1">
              <Image
                src={latestPost.data.cover}
                alt={latestPost.data.coverAlt || latestPost.data.title}
                class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04] group-hover:blur-sm group-focus-visible:scale-[1.04] group-focus-visible:blur-sm"
                widths={[720, 1080]}
                sizes="(max-width: 1024px) 100vw, 720px"
              />
              <div
                class="absolute inset-0 bg-background-0/70 opacity-0 backdrop-blur-sm transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
              ></div>
              <div
                class="absolute inset-x-0 bottom-0 translate-y-4 p-6 opacity-0 transition duration-300 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100 md:p-8"
              >
                <h3 class="max-w-3xl font-display text-4xl leading-tight text-white md:text-5xl">
                  {latestPost.data.title}
                </h3>
              </div>
            </div>
            <div
              class="border-t border-border px-6 py-4 font-mono text-[11px] tracking-[0.2em] text-foreground-2 uppercase md:px-8"
            >
              <div class="flex items-center justify-between gap-4">
                <span>{latestPost.data.pubDatetime.toISOString().slice(0, 10)}</span>
                <span class="flex items-center gap-2 text-foreground-1 transition-colors group-hover:text-accent-1">
                  Read article
                  <Icon name="arrow-right" class="size-4" />
                </span>
              </div>
            </div>
          </a>
        </div>

        <div data-home-panel="video" class="hidden">
          <div class="overflow-hidden bg-background-0">
            <button
              type="button"
              class="group relative block aspect-og w-full overflow-hidden bg-background-1 text-left"
              data-video-open
              aria-label="Open latest video"
            >
              <img
                src={videoThumb}
                alt="Latest video thumbnail"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04] group-hover:blur-sm group-focus-visible:scale-[1.04] group-focus-visible:blur-sm"
              />
              <span
                class="absolute inset-0 grid place-items-center bg-background-0/55 opacity-0 backdrop-blur-sm transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
              >
                <span class="border border-accent-1 px-5 py-3 font-mono text-xs tracking-[0.2em] text-white uppercase">
                  Play video
                </span>
              </span>
            </button>
            <div class="border-t border-border px-6 py-4 md:px-8">
              <div class="flex flex-col gap-3 sm:flex-row">
                <button type="button" class={buttonVariants({ variant: "default", size: "lg" })} data-video-open>
                  Open Video
                </button>
                <a
                  href="https://www.youtube.com/@hyperoot"
                  target="_blank"
                  rel="noopener noreferrer"
                  class={buttonVariants({ variant: "outline", size: "lg" })}
                >
                  Visit Channel
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div
    id="video-overlay"
    data-video-url={videoUrl}
    class="fixed inset-0 z-80 hidden items-center justify-center bg-background-0/90 p-4 backdrop-blur-sm"
  >
    <div class="relative w-full max-w-5xl border border-border bg-background-0">
      <button
        type="button"
        id="video-overlay-close"
        class="absolute -top-12 right-0 border border-border bg-background-0 px-4 py-3 font-mono text-xs tracking-[0.2em] text-foreground-1 uppercase transition-colors hover:bg-background-1"
        aria-label="Close video overlay"
      >
        Close
      </button>
      <div class="aspect-video w-full">
        <iframe
          id="video-overlay-frame"
          class="h-full w-full"
          title="Latest video"
          src=""
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen></iframe>
      </div>
    </div>
  </div>
</div>

<style>
  .home-hero {
    min-height: calc(100svh - 5.5rem);
  }

  .home-hero-shell {
    min-height: calc(100svh - 5.5rem);
    row-gap: clamp(1rem, 3svh, 2.5rem);
    padding-top: clamp(1.5rem, 4svh, 2.75rem);
    padding-bottom: clamp(1.25rem, 3svh, 2rem);
  }

  .home-hero-heading {
    max-width: min(34rem, 46vw);
  }

  .home-hero-heading h1 {
    font-size: clamp(2rem, 3.05vw, 3.6rem);
  }

  .home-hero-bottom {
    column-gap: clamp(2rem, 7vw, 5rem);
  }

  .home-hero-intro p:not(:first-child) {
    max-width: 31rem;
  }

  .home-hero-cases {
    align-items: end;
  }

  .home-case-card {
    min-width: 0;
  }

  .home-case-visual {
    aspect-ratio: 16 / 9;
    height: auto;
  }

  .home-case-content {
    padding: clamp(0.875rem, 1.4vw, 1.25rem);
  }

  .home-case-title {
    font-size: clamp(1.1rem, 1.25vw, 1.4rem);
  }

  .home-case-body {
    font-size: clamp(0.78rem, 0.85vw, 0.9rem);
  }

  @media (max-width: 1180px) {
    .home-hero-heading {
      max-width: 28rem;
    }

    .home-hero-heading h1 {
      font-size: clamp(1.85rem, 3.35vw, 2.75rem);
    }

    .home-hero-bottom {
      grid-template-columns: minmax(17rem, 0.68fr) minmax(28rem, 1fr);
      gap: 2rem;
    }

    .home-case-content {
      padding: 0.95rem;
    }

    .home-case-body {
      font-size: 0.8125rem;
      line-height: 1.5;
    }
  }

  @media (max-height: 760px) and (min-width: 901px) {
    .home-hero-shell {
      padding-top: 1rem;
      padding-bottom: 1rem;
      row-gap: 0.75rem;
    }

    .home-hero-heading {
      max-width: 30rem;
    }

    .home-hero-heading h1 {
      font-size: clamp(1.75rem, 2.65vw, 2.65rem);
      line-height: 1;
    }

    .home-hero-intro p:not(:first-child) {
      font-size: 0.95rem;
      line-height: 1.55;
      max-width: 30rem;
    }

    .home-hero-intro .mt-7 {
      margin-top: 1.25rem;
    }

    .home-case-content {
      padding: 0.8rem 0.9rem;
    }

    .home-case-title {
      margin-top: 0.55rem;
      font-size: 1.1rem;
    }

    .home-case-body {
      display: none;
    }

    .home-case-content .mt-5 {
      margin-top: 0.75rem;
      padding-top: 0.75rem;
    }
  }

  @media (max-width: 900px) {
    .home-hero {
      min-height: auto;
    }

    .home-hero-shell {
      min-height: auto;
      grid-template-rows: auto auto;
      padding-top: 2rem;
      padding-bottom: 2rem;
    }

    .home-hero-shell > [aria-hidden="true"] {
      display: none;
    }

    .home-hero-heading {
      max-width: 42rem;
      padding-bottom: clamp(4rem, 12svh, 8rem);
    }

    .home-hero-heading h1 {
      font-size: clamp(2.25rem, 8vw, 4.5rem);
    }

    .home-hero-bottom {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .home-hero-cases {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  @media (max-width: 640px) {
    .home-hero-heading {
      padding-bottom: 3rem;
    }

    .home-hero-heading h1 {
      font-size: clamp(2rem, 10vw, 3.25rem);
    }

    .home-hero-cases {
      grid-template-columns: 1fr;
    }
  }

  .home-project-field {
    background-image:
      linear-gradient(90deg, color-mix(in oklab, var(--border) 80%, transparent) 1px, transparent 1px),
      linear-gradient(color-mix(in oklab, var(--border) 80%, transparent) 1px, transparent 1px),
      linear-gradient(135deg, color-mix(in oklab, var(--accent-1) 18%, transparent), transparent 42%);
    background-size: 26px 26px, 26px 26px, 100% 100%;
  }

  .home-reveal-line {
    display: block;
    animation: home-text-reveal both linear;
    animation-timeline: view();
    animation-range: entry 5% cover 45%;
  }

  .home-reveal-line:nth-child(2) {
    animation-range: entry 12% cover 52%;
  }

  .home-reveal-line:nth-child(3) {
    animation-range: entry 20% cover 60%;
  }

  @keyframes home-text-reveal {
    0% {
      opacity: 0.18;
      filter: blur(10px);
      transform: translateY(18px);
    }

    100% {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-reveal-line {
      animation: none;
      opacity: 1;
      filter: none;
      transform: none;
    }
  }
</style>

<script>
  const setupLocalTime = () => {
    const target = document.querySelector("[data-local-time]");
    if (!target) return;

    const update = () => {
      const time = new Intl.DateTimeFormat("en-US", {
        timeZone: "Asia/Kolkata",
        hour: "numeric",
        minute: "2-digit",
        second: "2-digit",
        hour12: true,
      }).format(new Date());

      target.textContent = `Now, ${time} IST`;
    };

    update();
    const interval = window.setInterval(update, 1000);
    document.addEventListener("astro:before-swap", () => window.clearInterval(interval), { once: true });
  };

  const setupHomepageExperience = () => {
    const tabs = Array.from(document.querySelectorAll("[data-home-tab]"));
    const panels = Array.from(document.querySelectorAll("[data-home-panel]"));
    const overlay = document.getElementById("video-overlay");
    const frame = document.getElementById("video-overlay-frame");
    const closeButton = document.getElementById("video-overlay-close");
    const openButtons = Array.from(document.querySelectorAll("[data-video-open]"));
    const videoUrl = overlay?.getAttribute("data-video-url") || "";

    if (tabs.length && panels.length) {
      const activatePanel = (name: string) => {
        tabs.forEach((tab) => {
          const tabElement = tab as HTMLElement;
          const active = tabElement.getAttribute("data-panel") === name;
          tabElement.dataset.active = active ? "true" : "false";
          tabElement.setAttribute("aria-selected", active ? "true" : "false");
        });

        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.getAttribute("data-home-panel") !== name);
        });
      };

      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const panelName = tab.getAttribute("data-panel");
          if (panelName) activatePanel(panelName);
        });
      });
    }

    const closeOverlay = () => {
      if (!overlay || !frame) return;
      overlay.classList.add("hidden");
      overlay.classList.remove("flex");
      frame.setAttribute("src", "");
      document.documentElement.classList.remove("overflow-hidden");
    };

    const openOverlay = () => {
      if (!overlay || !frame) return;
      overlay.classList.remove("hidden");
      overlay.classList.add("flex");
      frame.setAttribute("src", videoUrl);
      document.documentElement.classList.add("overflow-hidden");
    };

    openButtons.forEach((button) => button.addEventListener("click", openOverlay));
    closeButton?.addEventListener("click", closeOverlay);
    overlay?.addEventListener("click", (event) => {
      if (event.target === overlay) closeOverlay();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeOverlay();
    });
  };

  document.addEventListener("astro:page-load", () => {
    setupLocalTime();
    setupHomepageExperience();
  });
</script>
