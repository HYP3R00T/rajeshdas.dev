---
// Header Component - Navigation and branding
import { navItems } from "@data/config";
import { ModeToggle } from "@/components/core/ModeToggle";
import AnimatedText from "@/components/common/AnimatedText.tsx";
import MobileMenuToggle from "@/components/core/MobileMenuToggle.astro";
import MobileMenuPanel from "@/components/core/MobileMenuPanel.astro";
---

<header
  data-header-shell
  data-menu-open="false"
  class="sticky top-0 z-50 px-4 py-4 md:px-8 md:py-5"
>
  <nav
    data-header-nav
    data-menu-open="false"
    class="mx-auto w-full max-w-site rounded-lg border border-border bg-background-1/90 px-4 py-3 backdrop-blur-xl transition-[border-radius] data-[menu-open=true]:rounded-b-none md:px-6"
  >
    <div class="flex items-center gap-4">
      <a href="/" class="flex flex-1 flex-row font-mono text-base md:text-lg">
        <AnimatedText client:load text="rajeshdas" className="text-accent-1" auto={true} hover={true} />
        <div class="text-foreground-3">.dev</div>
      </a>

      <div class="hidden flex-1 items-center justify-center gap-2 font-mono md:flex">
        {
          navItems
            .filter((item) => !item.special)
            .map((item) => (
              <a
                href={item.href}
                target={item.blank ? "_blank" : undefined}
                rel={item.blank ? "noopener noreferrer" : undefined}
                class="px-4 py-2 text-sm text-foreground-2 transition-colors hover:text-accent-1"
              >
                {item.label}
              </a>
            ))
        }
      </div>

      <div class="hidden flex-1 items-center justify-end gap-2 md:flex">
        <ModeToggle client:load />
      </div>

      <MobileMenuToggle />
    </div>
  </nav>
</header>

<!-- Mobile Menu Panel -->
<MobileMenuPanel navItems={navItems.filter((item) => !item.special)} />

<!-- AnimatedText component handles the animation behavior -->
