---
// Header Component - Navigation and branding
import { navItems, SITE } from "@data/config";
import { Button } from "@/components/ui/button";
import { Icon } from "astro-icon/components";
import { ModeToggle } from "@/components/core/ModeToggle";
import { User } from "lucide-react";
import MobileMenuToggle from "@/components/core/MobileMenuToggle.astro";
import MobileMenuPanel from "@/components/core/MobileMenuPanel.astro";
---

<header
  class="border-border sticky top-0 z-50 flex items-center justify-center border-b bg-background-0 backdrop-blur-xl px-4 py-4 md:py-6 md:px-12"
>
  <nav class="mx-auto w-full max-w-7xl">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex flex-row font-mono items-end" id="whoami">
        <div class="text-accent-1" id="name">rajeshdas</div>
        <div class="text-foreground-3">.dev</div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden items-center gap-12 md:flex font-mono">
        {
          navItems
            .filter((item) => !item.special)
            .map((item) => (
              <a
                href={item.href}
                target={item.blank ? "_blank" : undefined}
                rel={item.blank ? "noopener noreferrer" : undefined}
              >
                <div class="text-sm text-foreground-2 hover:text-accent-1">{item.label}</div>
              </a>
            ))
        }
      </div>

      <div class="hidden items-center gap-2 md:flex">
        <a href={SITE.repo} target="_blank" class="hidden md:block">
          <Button size="icon" variant="ghost" className="text-foreground-2">
            <Icon name="github" />
          </Button>
        </a>
        <a href="https://rajeshdas.dev" target="_blank" class="hidden md:block">
          <Button size="icon" variant="ghost" className="text-foreground-2">
            <User />
          </Button>
        </a>

        <!-- Theme Toggle -->
        <ModeToggle client:load />
      </div>

      <!-- Mobile Menu Toggle -->
      <MobileMenuToggle />
    </div>
  </nav>
</header>

<!-- Mobile Menu Panel -->
<MobileMenuPanel navItems={navItems.filter((item) => !item.special)} />

<script>
  document.addEventListener("astro:page-load", () => {
    const name: any = document.getElementById("name");
    const whoami: any = document.getElementById("whoami");

    whoami.addEventListener("mouseover", () => {
      name.innerText = "rajeshdas";
      name.dataset.value = "rajeshdas";
      const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789abcdefghijklmnopqrstuvwxyz";
      let interval: any = null;
      let iteration = 0;
      clearInterval(interval);

      interval = setInterval(() => {
        name.innerText = name.innerText
          .split("")
          .map((letter: any, index: any) => {
            if (index < iteration) {
              return name.dataset.value[index];
            }

            return letters[Math.floor(Math.random() * 62)];
          })
          .join("");

        if (iteration >= name.dataset.value.length) {
          clearInterval(interval);
        }

        iteration += 1 / 3;
      }, 30);
    });

    whoami.addEventListener("mouseout", () => {
      name.innerText = "rajeshdas";
      name.dataset.value = "rajeshdas";
      const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789abcdefghijklmnopqrstuvwxyz";
      let interval: any = null;
      let iteration = 0;
      clearInterval(interval);

      interval = setInterval(() => {
        name.innerText = name.innerText
          .split("")
          .map((letter: any, index: any) => {
            if (index < iteration) {
              return name.dataset.value[index];
            }

            return letters[Math.floor(Math.random() * 62)];
          })
          .join("");

        if (iteration >= name.dataset.value.length) {
          clearInterval(interval);
        }

        iteration += 1 / 3;
      }, 30);
    });
  });
</script>
