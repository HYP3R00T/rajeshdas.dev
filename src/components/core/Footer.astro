---
import { Icon } from "astro-icon/components";
import { SITE, navItems, SOCIAL_LINKS } from "@data/config";

const currentYear = new Date().getFullYear();
const activeSocials = SOCIAL_LINKS.filter((s) => s.active);
---

<footer class="stripe-pattern-dense border-border border-t">
  <div class="mx-auto w-full max-w-7xl px-6 md:px-12">
    <!-- Main footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-3">
      <!-- Brand column -->
      <div class="border-border border-b p-8 md:border-r md:border-b-0 md:py-12 md:pr-12 md:pl-0">
        <div class="text-foreground-0 font-display mb-4 text-lg font-semibold tracking-wide uppercase">
          {SITE.author}
        </div>
        <p class="text-foreground-2 text-sm leading-relaxed">
          Building robust infrastructure and automation tools for modern
          development teams.
        </p>
      </div>

      <!-- Navigation column -->
      <div class="border-border border-b p-8 md:border-r md:border-b-0 md:py-12 md:px-12">
        <div class="text-foreground-3 mb-6 text-xs font-medium tracking-widest uppercase">
          Navigation
        </div>
        <nav class="flex flex-col gap-3">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                target={item.blank ? "_blank" : undefined}
                rel={item.blank ? "noopener noreferrer" : undefined}
                class="text-foreground-1 hover:text-foreground-0 w-fit text-sm tracking-wide uppercase transition-colors"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Social column -->
      <div class="p-8 md:py-12 md:pl-12 md:pr-0">
        <div class="text-foreground-3 mb-6 text-xs font-medium tracking-widest uppercase">
          Connect
        </div>
        <div class="flex flex-col gap-3">
          {
            activeSocials.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                title={social.linkTitle}
                class="text-foreground-1 hover:text-foreground-0 flex w-fit items-center gap-3 text-sm tracking-wide uppercase transition-colors"
              >
                <Icon name={social.name} class="size-4" />
                {social.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-border flex items-center justify-between border-t py-6">
      <div class="text-foreground-3 text-xs tracking-wide">
        &copy; {currentYear} {SITE.author}
      </div>
      <a
        href={SITE.repo}
        target="_blank"
        rel="noopener noreferrer"
        class="text-foreground-3 hover:text-foreground-0 text-xs tracking-wide uppercase transition-colors"
      >
        Source
      </a>
    </div>
  </div>
</footer>
