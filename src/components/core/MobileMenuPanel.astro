---
interface Props {
  navItems: Array<{ label: string; href: string; blank?: boolean }>;
}

const { navItems } = Astro.props as Props;

import { SITE } from "@data/config";
import { Icon } from "astro-icon/components";
import { Button } from "@/components/ui/button";
import { User } from "lucide-react";
---

<!-- Panel (full-screen overlay below header). Visibility controlled via data-open attr -->
<div
  id="mobile-menu"
  data-mobile-menu
  data-open="false"
  class="border-border pointer-events-none fixed inset-x-0 top-0 z-40 overflow-auto border-t bg-background opacity-0 transition duration-150 ease-out data-[open=true]:pointer-events-auto data-[open=true]:translate-y-0 data-[open=true]:opacity-100 md:hidden"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
>
  <div class="px-4 py-4">
    <nav class="space-y-4">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            target={item.blank ? "_blank" : undefined}
            rel={item.blank ? "noopener noreferrer" : undefined}
            class="text-foreground-2 hover:text-foreground block text-sm tracking-wider uppercase transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="mt-6 pt-6 flex items-center gap-3">
      <a href={SITE.repo} target="_blank" rel="noopener noreferrer" class="block">
        <Button size="icon" variant="outline" aria-label="GitHub">
          <Icon name="github" />
        </Button>
      </a>
      <a href="https://rajeshdas.dev" target="_blank" rel="noopener noreferrer" class="block">
        <Button size="icon" variant="outline" aria-label="Personal site">
          <User />
        </Button>
      </a>
    </div>
  </div>
</div>
