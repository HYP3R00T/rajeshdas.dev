---
interface Props {
  navItems: Array<{ label: string; href: string; blank?: boolean }>;
}

const { navItems } = Astro.props as Props;

import { ModeToggle } from "@/components/core/ModeToggle";
---

<div
  id="mobile-menu"
  data-mobile-menu
  data-open="false"
  class="pointer-events-none fixed top-20 right-4 left-4 z-40 mx-auto w-auto max-w-site max-h-0 -translate-y-2 overflow-hidden rounded-b-lg border-x border-b border-border bg-background-0/95 opacity-0 backdrop-blur-xl transition-all duration-300 ease-out data-[open=true]:pointer-events-auto data-[open=true]:max-h-[calc(100svh-7rem)] data-[open=true]:translate-y-0 data-[open=true]:overflow-y-auto data-[open=true]:opacity-100 md:hidden"
  role="dialog"
  aria-hidden="true"
>
  <div class="p-4 sm:p-5">
    <nav class="grid gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            target={item.blank ? "_blank" : undefined}
            rel={item.blank ? "noopener noreferrer" : undefined}
            class="block px-1 py-3 font-display text-lg text-foreground-1 transition-colors hover:text-accent-1"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="mt-3 flex justify-end">
      <ModeToggle client:load />
    </div>
  </div>
</div>
