---
interface Props {
  navItems: Array<{ label: string; href: string; blank?: boolean }>;
}

const { navItems } = Astro.props as Props;

import { buttonVariants } from "@/components/ui/button";
import { ModeToggle } from "@/components/core/ModeToggle";
import { Icon } from "astro-icon/components";
---

<div
  id="mobile-menu"
  data-mobile-menu
  data-open="false"
  class="pointer-events-none fixed inset-x-0 top-20 z-40 mx-auto w-full max-w-site max-h-0 -translate-y-2 overflow-hidden rounded-b-lg border-x border-b border-border bg-background-0/95 opacity-0 shadow-sm backdrop-blur-xl transition-all duration-300 ease-out data-[open=true]:pointer-events-auto data-[open=true]:max-h-96 data-[open=true]:translate-y-0 data-[open=true]:opacity-100 md:hidden"
  role="dialog"
  aria-hidden="true"
>
  <div class="px-5 py-5">
    <nav class="divide-y divide-border border-b border-border">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            target={item.blank ? "_blank" : undefined}
            rel={item.blank ? "noopener noreferrer" : undefined}
            class="block py-4 font-display text-lg text-foreground-1 transition-colors hover:text-accent-1"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="mt-6 flex items-center justify-between gap-3">
      <a href="/contact" class={buttonVariants({ variant: "default", size: "lg" })}>
        <Icon name="arrow-right" class="size-4" />
        Let&apos;s Work Together
      </a>
      <ModeToggle client:load />
    </div>
  </div>
</div>
