<style>
  :global(.code-block) {
    overflow: hidden;
    margin-block: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  :global(.code-block__header) {
    display: flex;
    height: 2.5rem;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    padding-left: 1rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
  }

  :global(.code-block__meta) {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.625rem;
  }

  :global(.code-block__language) {
    flex: none;
    opacity: 0.62;
    text-transform: uppercase;
  }

  :global(.code-block__filename) {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.code-block__filename::before) {
    margin-right: 0.625rem;
    opacity: 0.38;
    content: "/";
  }

  :global(.code-block__copy) {
    align-self: stretch;
    flex: none;
    border: 0;
    border-left: 1px solid color-mix(in srgb, currentColor 14%, transparent);
    padding-inline: 0.875rem;
    background: transparent;
    color: inherit;
    font: inherit;
    letter-spacing: inherit;
    cursor: pointer;
    opacity: 0.65;
    transition:
      background-color 150ms ease,
      opacity 150ms ease;
  }

  :global(.code-block__copy:hover) {
    background: color-mix(in srgb, currentColor 7%, transparent);
    opacity: 1;
  }

  :global(.code-block__copy:focus-visible) {
    outline: 2px solid var(--accent-1);
    outline-offset: -3px;
    opacity: 1;
  }

  :global(.code-block__copy[data-copied="true"]) {
    opacity: 1;
  }

  :global(.prose .code-block pre) {
    margin: 0;
    border: 0;
    border-radius: 0;
    padding: 1.125rem 1.25rem;
    background: transparent !important;
  }

  :global(.prose .code-block pre code) {
    display: grid;
    min-width: max-content;
  }
</style>

<script>
  function initCodeCopyButtons() {
    document.querySelectorAll("[data-code-copy]").forEach((copyButton) => {
      if (!(copyButton instanceof HTMLButtonElement) || copyButton.dataset.initialized === "true") return;

      copyButton.dataset.initialized = "true";
      copyButton.addEventListener("click", async () => {
        const code = copyButton.closest("[data-code-block]")?.querySelector("code");
        if (!code || !navigator.clipboard) return;

        await navigator.clipboard.writeText(code.textContent ?? "");
        copyButton.textContent = "Copied";
        copyButton.dataset.copied = "true";

        setTimeout(() => {
          copyButton.textContent = "Copy";
          delete copyButton.dataset.copied;
        }, 1800);
      });
    });
  }

  initCodeCopyButtons();
  document.addEventListener("astro:page-load", initCodeCopyButtons);
</script>
