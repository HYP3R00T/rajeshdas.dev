---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { Button, buttonVariants } from "@/components/ui/button";
import { estimateReadTime, formatDateUppercase } from "@/lib/utils";
import MobileContentMeta from "@/components/common/MobileContentMeta.astro";
import DesktopContentToc from "@/components/common/DesktopContentToc";
import { SITE } from "@data/config";

const {
  slug,
  title,
  description,
  pubDatetime,
  modDatetime,
  tags,
  cover,
  coverAlt,
  ogImage,
  ogImageAlt,
  headings = [],
  body,
} = Astro.props;
const seoImage = ogImage || cover;
const seoImageAlt = ogImageAlt || coverAlt || title;
const readTime = body ? estimateReadTime(body) : 5;
const visibleHeadings = headings
  .filter((heading: { depth: number }) => heading.depth > 1 && heading.depth < 4);
const mobileMetaItems = [
  { label: "Published", value: formatDateUppercase(pubDatetime), datetime: pubDatetime.toISOString() },
  { label: "Read time", value: `${readTime} min` },
  ...(modDatetime
    ? [{ label: "Updated", value: formatDateUppercase(modDatetime), datetime: modDatetime.toISOString() }]
    : []),
  { label: "Author", value: SITE.author },
];
---

<BaseLayout title={title} description={description} image={seoImage} imageAlt={seoImageAlt} contentType="Article">
  <section class="px-4 pt-12 pb-20 md:px-8 md:pt-18 md:pb-28">
    <div class="mx-auto w-full max-w-site">
      <div class="mx-auto w-full max-w-352 xl:ml-auto xl:mr-0">
        <a href="/post" class={`${buttonVariants({ variant: "outline", size: "sm" })} mb-10`}>
          <Icon name="arrow-left" class="size-4" />
          Articles
        </a>

        <div
          class="grid gap-10 lg:grid-cols-[16rem_minmax(0,44rem)_minmax(0,8rem)] lg:gap-12 xl:grid-cols-[18rem_minmax(0,46rem)_minmax(0,10rem)] xl:gap-16"
        >
          <aside class="hidden lg:order-1 lg:sticky lg:top-28 lg:flex lg:h-[calc(100vh-9rem)] lg:flex-col lg:self-start">
            <div class="shrink-0 rounded-lg border border-border/80 bg-background-1 p-5">
              <div class="space-y-5">
                <div>
                  <p class="font-mono text-xs text-foreground-3 uppercase">Published</p>
                  <time class="mt-2 block text-sm text-foreground-1" datetime={pubDatetime.toISOString()}>
                    {formatDateUppercase(pubDatetime)}
                  </time>
                </div>

                <div>
                  <p class="font-mono text-xs text-foreground-3 uppercase">Read time</p>
                  <p class="mt-2 text-sm text-foreground-1">{readTime} min</p>
                </div>

                {
                  modDatetime && (
                    <div>
                      <p class="font-mono text-xs text-foreground-3 uppercase">Updated</p>
                      <time class="mt-2 block text-sm text-foreground-1" datetime={modDatetime.toISOString()}>
                        {formatDateUppercase(modDatetime)}
                      </time>
                    </div>
                  )
                }

                <div>
                  <p class="font-mono text-xs text-foreground-3 uppercase">Author</p>
                  <p class="mt-2 text-sm text-foreground-1">{SITE.author}</p>
                </div>
              </div>

              {
                tags && tags.length > 0 && (
                  <div class="mt-6 flex flex-wrap gap-2">
                    {tags.map((tag: string) => (
                      <Badge variant="secondary" className="border border-border/80 bg-background-2 text-foreground-1">
                        {tag}
                      </Badge>
                    ))}
                  </div>
                )
              }

              <Button data-share-button variant="outline" size="sm" className="mt-6 w-full justify-between">
                Share article
                <Icon name="arrow-up-right" class="size-4" />
              </Button>
            </div>

            {
              visibleHeadings.length > 0 && (
                <DesktopContentToc client:load headings={visibleHeadings} label="Article sections" />
              )
            }
          </aside>

          <article class="order-1 lg:order-2">
            <header>
              <h1
                class="font-display text-4xl leading-tight font-semibold tracking-tighter text-foreground-0 md:text-5xl xl:text-6xl"
                transition:name={`post-title-${slug}`}
              >
                {title}
              </h1>
              <p class="mt-7 max-w-2xl text-lg leading-relaxed text-foreground-2 md:text-xl">
                {description}
              </p>
            </header>

            <MobileContentMeta items={mobileMetaItems} tags={tags} headings={visibleHeadings} shareLabel="Share article" />

            <div class="mt-14 w-full">
              <div
                class="overflow-hidden rounded-lg border border-border/80 bg-background-1 p-3"
                transition:name={`post-cover-${slug}`}
              >
                <div class="aspect-og overflow-hidden rounded-md bg-background-1">
                  <Image
                    src={cover}
                    alt={coverAlt || title}
                    class="h-full w-full object-cover"
                    widths={[720, 960, 1280, 1600]}
                    sizes="(min-width: 1024px) 46rem, calc(100vw - 2rem)"
                  />
                </div>
              </div>
            </div>

            <div class="prose mt-16 max-w-none">
              <slot />
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const setupShareButton = () => {
    document.querySelectorAll<HTMLElement>("[data-share-button]").forEach((button) => {
      button.addEventListener("click", async () => {
        const url = window.location.href;
        const title = document.title;

        if (navigator.share) {
          try {
            await navigator.share({ title, url });
          } catch {
            // Sharing was dismissed; no visible recovery is needed.
          }
          return;
        }

        try {
          await navigator.clipboard.writeText(url);
          const originalText = button.innerHTML;
          button.innerHTML = "Copied";
          window.setTimeout(() => {
            button.innerHTML = originalText;
          }, 1600);
        } catch {
          button.setAttribute("data-copy-failed", "true");
        }
      });
    });
  };

  const setupActiveTableOfContents = () => {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"));
    if (links.length === 0) return;

    const linkById = new Map(links.map((link) => [link.dataset.tocLink, link]));
    const headings = Array.from(document.querySelectorAll<HTMLElement>(".prose :is(h2, h3)[id]")).filter((heading) =>
      linkById.has(heading.id),
    );
    if (headings.length === 0) return;

    const setActive = (id: string) => {
      for (const link of links) {
        const isActive = link.dataset.tocLink === id;
        link.classList.toggle("border-accent-1", isActive);
        link.classList.toggle("text-accent-1", isActive);
        link.classList.toggle("translate-x-1", isActive);
        link.classList.toggle("text-foreground-2", !isActive);
        link.setAttribute("aria-current", isActive ? "location" : "false");
      }
    };

    setActive(headings[0].id);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

        if (visible?.target instanceof HTMLElement) {
          setActive(visible.target.id);
        }
      },
      {
        rootMargin: "-22% 0px -62% 0px",
        threshold: [0, 1],
      },
    );

    headings.forEach((heading) => observer.observe(heading));
    document.addEventListener("astro:before-swap", () => observer.disconnect(), { once: true });
  };

  document.addEventListener("astro:page-load", () => {
    setupShareButton();
    setupActiveTableOfContents();
  });
</script>
