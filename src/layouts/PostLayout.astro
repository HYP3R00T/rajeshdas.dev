---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import SectionHeader from "@/components/core/SectionHeader.astro";
import SiteSection from "@/components/core/SiteSection.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BackButton from "@/components/ui/BackButton.astro";
import { Button } from "@/components/ui/button";
import { estimateReadTime, formatDateUppercase } from "@/lib/utils";
import MobileContentMeta from "@/components/common/MobileContentMeta.astro";
import DesktopContentToc from "@/components/common/DesktopContentToc";
import FocusModeToggle from "@/components/common/FocusModeToggle.astro";
import { SITE } from "@data/config";

const {
  slug,
  title,
  description,
  pubDatetime,
  modDatetime,
  tags,
  category,
  cover,
  coverAlt,
  ogImage,
  ogImageAlt,
  headings = [],
  body,
} = Astro.props;
const seoImage = ogImage || cover;
const seoImageAlt = ogImageAlt || coverAlt || title;
const readTime = body ? estimateReadTime(body) : 5;
const categoryLabel = category ? `${category.charAt(0).toUpperCase()}${category.slice(1)} article` : "Article";
const visibleHeadings = headings
  .filter((heading: { depth: number }) => heading.depth > 1 && heading.depth < 4);
const mobileMetaItems = [
  { label: "Published", value: formatDateUppercase(pubDatetime), datetime: pubDatetime.toISOString() },
  { label: "Read time", value: `${readTime} min` },
  ...(category ? [{ label: "Category", value: categoryLabel.replace(" article", "") }] : []),
  ...(modDatetime
    ? [{ label: "Updated", value: formatDateUppercase(modDatetime), datetime: modDatetime.toISOString() }]
    : []),
  { label: "Author", value: SITE.author },
];
---

<BaseLayout title={title} description={description} image={seoImage} imageAlt={seoImageAlt} contentType="Article">
  <section aria-labelledby="article-title" data-focus-introduction>
    <div class="site-grid-frame">
      <SectionHeader
        eyebrow={categoryLabel}
        title={title}
        titleId="article-title"
        headingLevel={1}
        description={description}
        transitionName={`post-title-${slug}`}
      >
        <FocusModeToggle slot="action" />
      </SectionHeader>
    </div>
  </section>

  <SiteSection
    aria-label="Article content"
    data-focus-content-section
    frameClass="focus-reading-frame lg:grid lg:grid-cols-[minmax(14rem,1fr)_minmax(0,3fr)]"
  >
    <aside
      class="hidden min-w-0 lg:sticky lg:top-16 lg:flex lg:h-[calc(100vh-4rem)] lg:flex-col lg:self-start lg:border-r lg:border-border lg:py-10"
      aria-label="Article navigation and information"
      data-focus-sidebar
    >
      <div class="shrink-0 px-8 xl:px-10">
        <BackButton href="/post" label="Back to articles" dataArticlesBack />
      </div>

      <div class="mt-8 shrink-0 border-t border-border px-8 pt-8 xl:px-10">
        <p class="font-mono text-[0.6875rem] tracking-[0.14em] text-accent-1 uppercase">Article details</p>
        <dl class="mt-5 grid grid-cols-2 gap-x-4 gap-y-4">
          <div>
            <dt class="font-mono text-[0.625rem] tracking-[0.12em] text-foreground-3 uppercase">Published</dt>
            <dd class="mt-1.5 text-sm text-foreground-1">
              <time datetime={pubDatetime.toISOString()}>{formatDateUppercase(pubDatetime)}</time>
            </dd>
          </div>
          <div>
            <dt class="font-mono text-[0.625rem] tracking-[0.12em] text-foreground-3 uppercase">Read time</dt>
            <dd class="mt-1.5 text-sm text-foreground-1">{readTime} min</dd>
          </div>
          {
            modDatetime && (
              <div class="col-span-2">
                <dt class="font-mono text-[0.625rem] tracking-[0.12em] text-foreground-3 uppercase">Updated</dt>
                <dd class="mt-1.5 text-sm text-foreground-1">
                  <time datetime={modDatetime.toISOString()}>{formatDateUppercase(modDatetime)}</time>
                </dd>
              </div>
            )
          }
          <div>
            <dt class="font-mono text-[0.625rem] tracking-[0.12em] text-foreground-3 uppercase">Author</dt>
            <dd class="mt-1.5 text-sm text-foreground-1">{SITE.author}</dd>
          </div>
          {
            tags && tags.length > 0 && (
              <div class="col-span-2">
                <dt class="font-mono text-[0.625rem] tracking-[0.12em] text-foreground-3 uppercase">Topics</dt>
                <dd class="mt-1.5 text-sm leading-6 text-foreground-1">{tags.join(" · ")}</dd>
              </div>
            )
          }
        </dl>

        <Button
          data-share-button
          className="relative mt-5 w-full border-0 bg-accent-1 px-10 text-accent-contrast hover:bg-accent-2"
        >
          <span>Share article</span>
          <Icon name="arrow-up-right" class="absolute right-3 size-4" />
        </Button>
      </div>

      {
        visibleHeadings.length > 0 && (
          <DesktopContentToc client:load headings={visibleHeadings} label="Article sections" variant="sidebar" />
        )
      }
    </aside>

    <article class="min-w-0" data-focus-reading-content>
      <div class="w-full">
        <div class="aspect-og w-full overflow-hidden" transition:name={`post-cover-${slug}`}>
          <Image
            src={cover}
            alt={coverAlt || title}
            class="h-full w-full object-cover"
            widths={[720, 960, 1280, 1600]}
            sizes="(min-width: 1024px) 63rem, 100vw"
          />
        </div>
      </div>

      <div class="prose max-w-none px-5 pt-12 pb-12 md:px-10 md:pt-16 md:pb-16 lg:px-12 xl:px-16">
        <slot />
      </div>

      <div class="border-t border-border px-5 py-10 md:px-10 md:py-12 lg:hidden" data-focus-mobile-meta>
        <BackButton href="/post" label="Back to articles" dataArticlesBack />
        <MobileContentMeta label="Article details" items={mobileMetaItems} tags={tags} shareLabel="Share article" />
      </div>

      <div class="focus-mode-only justify-end border-t border-border px-5 py-6 md:px-10 lg:px-12 xl:px-16">
        <FocusModeToggle />
      </div>
    </article>
  </SiteSection>
</BaseLayout>

<script>
  const setupArticleBackLinks = () => {
    const links = document.querySelectorAll<HTMLAnchorElement>("[data-articles-back]");
    if (links.length === 0) return;

    try {
      const storedUrl = window.sessionStorage.getItem("articleArchiveReturnUrl");
      if (!storedUrl) return;

      const returnUrl = new URL(storedUrl);
      if (returnUrl.origin !== window.location.origin || returnUrl.pathname.replace(/\/$/, "") !== "/post") return;

      for (const link of links) {
        link.href = returnUrl.toString();
      }
    } catch {
      // The fallback /post link remains valid when stored navigation state is unavailable.
    }
  };

  const setupShareButton = () => {
    document.querySelectorAll<HTMLElement>("[data-share-button]").forEach((button) => {
      button.addEventListener("click", async () => {
        const url = window.location.href;
        const title = document.title;

        if (navigator.share) {
          try {
            await navigator.share({ title, url });
          } catch {
            // Sharing was dismissed; no visible recovery is needed.
          }
          return;
        }

        try {
          await navigator.clipboard.writeText(url);
          const originalText = button.innerHTML;
          button.innerHTML = "Copied";
          window.setTimeout(() => {
            button.innerHTML = originalText;
          }, 1600);
        } catch {
          button.setAttribute("data-copy-failed", "true");
        }
      });
    });
  };

  const setupActiveTableOfContents = () => {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"));
    if (links.length === 0) return;

    const linkById = new Map(links.map((link) => [link.dataset.tocLink, link]));
    const headings = Array.from(document.querySelectorAll<HTMLElement>(".prose :is(h2, h3)[id]")).filter((heading) =>
      linkById.has(heading.id),
    );
    if (headings.length === 0) return;

    const setActive = (id: string) => {
      for (const link of links) {
        const isActive = link.dataset.tocLink === id;
        link.classList.toggle("border-accent-1", isActive);
        link.classList.toggle("text-accent-1", isActive);
        link.classList.toggle("translate-x-1", isActive);
        link.classList.toggle("text-foreground-2", !isActive);
        link.setAttribute("aria-current", isActive ? "location" : "false");
      }
    };

    setActive(headings[0].id);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

        if (visible?.target instanceof HTMLElement) {
          setActive(visible.target.id);
        }
      },
      {
        rootMargin: "-22% 0px -62% 0px",
        threshold: [0, 1],
      },
    );

    headings.forEach((heading) => observer.observe(heading));
    document.addEventListener("astro:before-swap", () => observer.disconnect(), { once: true });
  };

  document.addEventListener("astro:page-load", () => {
    setupArticleBackLinks();
    setupShareButton();
    setupActiveTableOfContents();
  });
</script>
