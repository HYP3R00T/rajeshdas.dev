---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/ui/Section.astro";
import SectionHeader from "@/components/ui/SectionHeader.astro";

const pageTitle = "Contact | Rajesh Das";
const pageDescription =
  "Ways to reach Rajesh Das for collaboration, hiring, or general conversation.";

const contactLinks = [
  {
    title: "Email",
    description: "Best for collaboration, hiring, and direct questions.",
    href: "mailto:hello@rajeshdas.dev",
  },
  {
    title: "GitHub",
    description: "See the code, projects, and open-source activity.",
    href: "https://github.com/HYP3R00T",
  },
  {
    title: "LinkedIn",
    description: "Professional connection and role-based conversation.",
    href: "https://linkedin.com/in/rajesh-kumar-das",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Section pattern="stripe">
    <SectionHeader
      badge="Contact"
      badgeVariant="accent"
      description="Use any of the links below if you want to collaborate, discuss a role, or simply continue the conversation."
    >
      <div>Ping Me</div>
    </SectionHeader>

    <div class="grid gap-4 md:grid-cols-3">
      {
        contactLinks.map((link) => (
          <a
            href={link.href}
            class="border-border bg-background-0 hover:border-foreground-3 hover:bg-background-1 focus-visible:ring-accent/60 flex flex-col gap-3 border p-5 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2"
          >
            <span class="font-display text-foreground-0 text-xl font-semibold">
              {link.title}
            </span>
            <span class="text-foreground-1 text-sm leading-relaxed">
              {link.description}
            </span>
          </a>
        ))
      }
    </div>
  </Section>
</BaseLayout>
