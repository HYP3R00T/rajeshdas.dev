---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buttonVariants } from "@/components/ui/button";
---

<BaseLayout>
  <section class="relative flex items-center justify-center px-4 md:px-12">
    <div class="mx-auto w-full max-w-5xl border-r border-l p-6 bg-background">
      <div class="mx-auto w-full">
        <div class="space-y-12 text-center">
          <!-- Large 404 display -->
          <div class="relative">
            <div
              class="text-foreground-2 md:text-48 font-display text-9xl leading-none font-background tracking-tighter select-none"
            >
              404
            </div>
          </div>

          <!-- Heading -->
          <div class="space-y-6">
            <h1 class="text-section-heading font-display text-center!">Lost in the void</h1>

            <!-- Witty message -->
            <div class="text-foreground-2 space-y-4">
              <p class="text-lg leading-relaxed md:text-xl">
                Looks like this page took an unplanned detour through a git rebase.
              </p>
              <p class="text-foreground-2 text-base">
                The file you're looking for has either been moved to a different branch, deleted, or never existed in
                the first place. Kind of like Docker layers you forgot to clean up.
              </p>
            </div>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-col justify-center gap-4 pt-6 sm:flex-row">
            <a href="/" class={buttonVariants({ variant: "default", size: "lg" })}> Go back home </a>
            <a href="/project" class={buttonVariants({ variant: "secondary", size: "lg" })}> Check my projects </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
