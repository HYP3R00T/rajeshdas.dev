---
import SiteSection from "@/components/core/SiteSection.astro";
import { buttonVariants } from "@/components/ui/button";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@data/config";

const pageTitle = `Not Found | ${SITE.title}`;
const pageDescription = "The page you're looking for isn't here, but the rest of the site still is.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <SiteSection
    aria-labelledby="not-found-title"
    frameClass="flex min-h-[34rem] items-center justify-center px-5 py-20 md:min-h-[38rem] md:px-10"
  >
    <div class="mx-auto flex max-w-xl flex-col items-center text-center">
      <h1
        id="not-found-title"
        class="font-display text-6xl leading-none font-medium tracking-[-0.04em] text-foreground-0 md:text-7xl"
      >
        404
      </h1>

      <p class="mt-5 text-base leading-7 text-foreground-2">
        The page you’re looking for doesn’t exist or may have moved.
      </p>

      <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row">
        <a href="/" class={buttonVariants({ variant: "default", size: "lg" })}>Back to home</a>
        <a href="/post/" class={buttonVariants({ variant: "ghost", size: "lg" })}>Browse articles</a>
      </div>

      <nav aria-label="Other useful destinations" class="mt-8 flex items-center gap-7 text-sm text-foreground-3">
        <a href="/learn/" class="transition-colors hover:text-accent-1">Learn</a>
        <a href="/til/" class="transition-colors hover:text-accent-1">Notes</a>
      </nav>
    </div>
  </SiteSection>
</BaseLayout>
