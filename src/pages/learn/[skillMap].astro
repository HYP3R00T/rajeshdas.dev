---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import SectionHeader from "@/components/core/SectionHeader.astro";
import SiteSection from "@/components/core/SiteSection.astro";
import BackButton from "@/components/ui/BackButton.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import RoadmapList from "@/components/learn/RoadmapList.astro";
import { getModuleSkillMapSlug, getSkillMapSlug, isModuleEntry, isSkillMapEntry } from "@/lib/learn";
import { SITE } from "@data/config";

export async function getStaticPaths() {
  const entries = await getCollection("learn");
  return entries
    .filter((entry) => isSkillMapEntry(entry) && entry.data.status === "ready")
    .map((entry) => ({
      params: { skillMap: getSkillMapSlug(entry) },
      props: { skillMap: entry },
    }));
}

const { skillMap } = Astro.props as { skillMap: any };
const skillMapSlug = getSkillMapSlug(skillMap);
const allEntries = await getCollection("learn");
const modules = (allEntries as Array<any>)
  .filter((entry) => isModuleEntry(entry) && getModuleSkillMapSlug(entry) === skillMapSlug && entry.data.status === "ready")
  .sort((a, b) => a.data.order - b.data.order);
const skillMapOgImage = skillMap.data.ogImage;
const skillMapOgImageAlt = skillMap.data.ogImageAlt || skillMap.data.title;
const moduleLabel = `${modules.length} module${modules.length === 1 ? "" : "s"}`;
---

<BaseLayout
  title={`${skillMap.data.title} | Learn | ${SITE.title}`}
  description={skillMap.data.description}
  image={skillMapOgImage}
  imageAlt={skillMapOgImageAlt}
  contentType="Article"
>
  <section aria-labelledby="skill-map-title">
    <div class="site-grid-frame">
      <SectionHeader
        eyebrow={`Skill map · ${moduleLabel}`}
        title={skillMap.data.title}
        titleId="skill-map-title"
        headingLevel={1}
        description={skillMap.data.description}
        transitionName={`skill-map-title-${skillMapSlug}`}
      />
    </div>
  </section>

  <SiteSection
    aria-label="Skill map overview and modules"
    frameClass="grid lg:grid-cols-[minmax(16rem,1fr)_minmax(0,3fr)]"
  >
    <aside class="min-w-0 border-b border-border lg:border-r lg:border-b-0">
      <div class="lg:sticky lg:top-16">
        <div class="border-b border-border px-5 py-8 md:px-8">
          <BackButton href="/learn/" label="All skill maps" />
        </div>

        <div class="border-b border-border px-5 py-8 md:px-8">
          <p class="font-mono text-[0.6875rem] tracking-[0.14em] text-accent-1 uppercase">Map details</p>
          <dl class="mt-6 grid gap-6">
            <div>
              <dt class="font-mono text-[0.625rem] tracking-[0.14em] text-foreground-3 uppercase">Modules</dt>
              <dd class="mt-2 text-sm text-foreground-1">{moduleLabel}</dd>
            </div>
            {
              skillMap.data.tags.length > 0 && (
                <div>
                  <dt class="font-mono text-[0.625rem] tracking-[0.14em] text-foreground-3 uppercase">Topics</dt>
                  <dd class="mt-2 text-sm leading-6 text-foreground-1">{skillMap.data.tags.join(" · ")}</dd>
                </div>
              )
            }
          </dl>
        </div>

        <div class="px-5 py-8 md:px-8">
          <p class="font-mono text-[0.6875rem] tracking-[0.14em] text-accent-1 uppercase">Outcome</p>
          <p class="mt-4 text-sm leading-6 text-foreground-2">{skillMap.data.outcome}</p>
        </div>
      </div>
    </aside>

    <div class="min-w-0">
      <div
        class="aspect-video overflow-hidden bg-background-1 md:aspect-[5/2]"
        transition:name={`skill-map-cover-${skillMapSlug}`}
      >
        <Image
          src={skillMap.data.cover}
          alt={skillMap.data.coverAlt || skillMap.data.title}
          class="h-full w-full object-cover"
          width={1332}
          height={533}
          fit="cover"
          position="center"
          quality="high"
        />
      </div>

      <RoadmapList skillMap={skillMap} modules={modules} />
    </div>
  </SiteSection>
</BaseLayout>
