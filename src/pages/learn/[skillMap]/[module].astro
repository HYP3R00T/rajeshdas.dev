---
import { Icon } from "astro-icon/components";
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { Button, buttonVariants } from "@/components/ui/button";
import { getModuleSkillMapSlug, getModuleSlug, getSkillMapSlug, isModuleEntry, isSkillMapEntry } from "@/lib/learn";
import { SITE } from "@data/config";

export async function getStaticPaths() {
  const entries = (await getCollection("learn")) as Array<any>;
  const skillMaps = entries.filter((entry) => isSkillMapEntry(entry) && entry.data.status === "ready");
  const modules = entries.filter((entry) => isModuleEntry(entry) && entry.data.status === "ready");

  return modules.flatMap((moduleEntry) => {
    const skillMapSlug = getModuleSkillMapSlug(moduleEntry);
    const skillMap = skillMaps.find((map) => getSkillMapSlug(map) === skillMapSlug);
    if (!skillMap) return [];

    return {
      params: { skillMap: skillMapSlug, module: getModuleSlug(moduleEntry) },
      props: { skillMap, moduleEntry },
    };
  });
}

const { skillMap, moduleEntry } = Astro.props as { skillMap: any; moduleEntry: any };
const skillMapSlug = getSkillMapSlug(skillMap);
const allEntries = (await getCollection("learn")) as Array<any>;
const modules = allEntries
  .filter((entry) => isModuleEntry(entry) && getModuleSkillMapSlug(entry) === skillMapSlug && entry.data.status === "ready")
  .sort((a, b) => a.data.order - b.data.order);
const currentIndex = modules.findIndex((entry) => entry.id === moduleEntry.id);
const previousModule = currentIndex > 0 ? modules[currentIndex - 1] : null;
const nextModule = currentIndex >= 0 && currentIndex < modules.length - 1 ? modules[currentIndex + 1] : null;
const { Content, headings } = await render(moduleEntry);
const visibleHeadings = headings.filter((heading: { depth: number }) => heading.depth > 1 && heading.depth < 4).slice(0, 10);
---

<BaseLayout title={`${moduleEntry.data.title} | ${skillMap.data.title} | Learn | ${SITE.title}`} description={moduleEntry.data.description}>
  <section class="px-4 pt-12 pb-20 md:px-8 md:pt-18 md:pb-28">
    <div class="mx-auto w-full max-w-site">
      <div class="mx-auto w-full max-w-[88rem] xl:ml-auto xl:mr-0">
        <div class="mb-10 flex flex-wrap gap-3">
          <a href="/learn/" class={buttonVariants({ variant: "outline", size: "sm" })}>
            <Icon name="arrow-left" class="size-4" />
            Learn
          </a>
          <a href={`/learn/${skillMapSlug}/`} class={buttonVariants({ variant: "outline", size: "sm" })}>
            {skillMap.data.title}
          </a>
        </div>

        <div class="grid gap-10 lg:grid-cols-[16rem_minmax(0,44rem)_minmax(0,8rem)] lg:gap-12 xl:grid-cols-[18rem_minmax(0,46rem)_minmax(0,10rem)] xl:gap-16">
          <aside class="order-2 lg:order-1 lg:sticky lg:top-28 lg:self-start">
            <div class="rounded-lg border border-border/80 bg-background-1 p-5">
              <div class="space-y-5">
                <div>
                  <p class="font-mono text-xs text-foreground-3 uppercase">Skill map</p>
                  <p class="mt-2 text-sm text-foreground-1">{skillMap.data.title}</p>
                </div>

                <div>
                  <p class="font-mono text-xs text-foreground-3 uppercase">Module</p>
                  <p class="mt-2 text-sm text-foreground-1">{String(currentIndex + 1).padStart(2, "0")}</p>
                </div>

                <div>
                  <p class="font-mono text-xs text-foreground-3 uppercase">Author</p>
                  <p class="mt-2 text-sm text-foreground-1">{SITE.author}</p>
                </div>
              </div>

              {moduleEntry.data.tags && moduleEntry.data.tags.length > 0 && (
                <div class="mt-6 flex flex-wrap gap-2">
                  {moduleEntry.data.tags.slice(0, 4).map((tag: string) => (
                    <Badge variant="secondary" className="border border-border/80 bg-background-2 text-foreground-1">
                      {tag}
                    </Badge>
                  ))}
                </div>
              )}

              <Button id="share-button" variant="outline" size="sm" className="mt-6 w-full justify-between">
                Share module
                <Icon name="arrow-up-right" class="size-4" />
              </Button>
            </div>

            {visibleHeadings.length > 0 && (
              <nav aria-label="Module sections" class="mt-5 rounded-lg border border-border/80 bg-background-1 p-5">
                <p class="font-mono text-xs text-foreground-3 uppercase">Sections</p>
                <ol class="mt-4 space-y-3">
                  {visibleHeadings.map((heading: { slug: string; text: string; depth: number }) => (
                    <li class={heading.depth === 3 ? "pl-3" : ""}>
                      <a
                        href={`#${heading.slug}`}
                        data-toc-link={heading.slug}
                        class="block border-l border-transparent py-1 pl-3 text-sm leading-snug text-foreground-2 transition-all duration-200 hover:text-accent-1"
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            )}

            {moduleEntry.data.prerequisites.length > 0 && (
              <details class="mt-5 rounded-lg border border-border/80 bg-background-1 p-5">
                <summary class="cursor-pointer font-mono text-xs text-foreground-3 uppercase transition-colors hover:text-accent-1">
                  Before you start
                </summary>
                <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed text-foreground-1">
                  {moduleEntry.data.prerequisites.map((item: string) => <li>{item}</li>)}
                </ul>
              </details>
            )}
          </aside>

          <article class="order-1 lg:order-2">
            <header>
              <p class="font-mono text-xs tracking-[0.28em] text-accent-1 uppercase">Module {String(currentIndex + 1).padStart(2, "0")}</p>
              <h1 class="mt-5 font-display text-5xl leading-none font-semibold tracking-tighter text-foreground-0 md:text-6xl xl:text-7xl">
                {moduleEntry.data.title}
              </h1>
              <p class="mt-6 max-w-2xl text-lg leading-relaxed text-foreground-1 md:text-xl">
                {moduleEntry.data.description}
              </p>
            </header>

            <div class="prose mt-14 max-w-none">
              <Content />
            </div>

            <nav class="mt-16 grid gap-4 border-t border-border pt-8 md:grid-cols-2" aria-label="Module navigation">
              {previousModule ? (
                <a href={`/learn/${skillMapSlug}/${getModuleSlug(previousModule)}/`} class="text-foreground-1 transition-colors hover:text-accent-1">
                  <span class="font-mono text-xs tracking-[0.24em] text-foreground-3 uppercase">Previous</span>
                  <span class="mt-3 block font-display text-xl text-foreground-0">{previousModule.data.title}</span>
                </a>
              ) : (
                <a href={`/learn/${skillMapSlug}/`} class="text-foreground-1 transition-colors hover:text-accent-1">
                  <span class="font-mono text-xs tracking-[0.24em] text-foreground-3 uppercase">Back</span>
                  <span class="mt-3 block font-display text-xl text-foreground-0">Return to skill map</span>
                </a>
              )}

              {nextModule ? (
                <a href={`/learn/${skillMapSlug}/${getModuleSlug(nextModule)}/`} class="text-foreground-1 transition-colors hover:text-accent-1 md:text-right">
                  <span class="font-mono text-xs tracking-[0.24em] text-foreground-3 uppercase">Next</span>
                  <span class="mt-3 block font-display text-xl text-foreground-0">{nextModule.data.title}</span>
                </a>
              ) : (
                <a href="/learn/" class="text-foreground-1 transition-colors hover:text-accent-1 md:text-right">
                  <span class="font-mono text-xs tracking-[0.24em] text-foreground-3 uppercase">Continue</span>
                  <span class="mt-3 block font-display text-xl text-foreground-0">Explore all maps</span>
                </a>
              )}
            </nav>
          </article>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const setupShareButton = () => {
    const button = document.getElementById("share-button");
    if (!button) return;

    button.addEventListener("click", async () => {
      const url = window.location.href;
      const title = document.title;

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
        } catch {
          // Sharing was dismissed; no visible recovery is needed.
        }
        return;
      }

      try {
        await navigator.clipboard.writeText(url);
        const originalText = button.innerHTML;
        button.innerHTML = "Copied";
        window.setTimeout(() => {
          button.innerHTML = originalText;
        }, 1600);
      } catch {
        button.setAttribute("data-copy-failed", "true");
      }
    });
  };

  const setupActiveTableOfContents = () => {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"));
    if (links.length === 0) return;

    const linkById = new Map(links.map((link) => [link.dataset.tocLink, link]));
    const headings = Array.from(document.querySelectorAll<HTMLElement>(".prose :is(h2, h3)[id]")).filter((heading) =>
      linkById.has(heading.id),
    );
    if (headings.length === 0) return;

    const setActive = (id: string) => {
      for (const link of links) {
        const isActive = link.dataset.tocLink === id;
        link.classList.toggle("border-accent-1", isActive);
        link.classList.toggle("text-accent-1", isActive);
        link.classList.toggle("translate-x-1", isActive);
        link.classList.toggle("text-foreground-2", !isActive);
        link.setAttribute("aria-current", isActive ? "location" : "false");
      }
    };

    setActive(headings[0].id);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

        if (visible?.target instanceof HTMLElement) {
          setActive(visible.target.id);
        }
      },
      {
        rootMargin: "-22% 0px -62% 0px",
        threshold: [0, 1],
      },
    );

    headings.forEach((heading) => observer.observe(heading));
    document.addEventListener("astro:before-swap", () => observer.disconnect(), { once: true });
  };

  document.addEventListener("astro:page-load", () => {
    setupShareButton();
    setupActiveTableOfContents();
  });
</script>
