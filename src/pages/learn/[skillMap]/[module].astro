---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Badge } from "@/components/ui/badge";
import { Button, buttonVariants } from "@/components/ui/button";
import { getModuleSkillMapSlug, getModuleSlug, getSkillMapSlug, isModuleEntry, isSkillMapEntry } from "@/lib/learn";
import { estimateReadTime, formatDateUppercase } from "@/lib/utils";
import { SITE } from "@data/config";

export async function getStaticPaths() {
  const entries = (await getCollection("learn")) as Array<any>;
  const skillMaps = entries.filter((entry) => isSkillMapEntry(entry) && entry.data.status === "ready");
  const modules = entries.filter((entry) => isModuleEntry(entry) && entry.data.status === "ready");

  return modules.flatMap((moduleEntry) => {
    const skillMapSlug = getModuleSkillMapSlug(moduleEntry);
    const skillMap = skillMaps.find((map) => getSkillMapSlug(map) === skillMapSlug);
    if (!skillMap) return [];

    return {
      params: { skillMap: skillMapSlug, module: getModuleSlug(moduleEntry) },
      props: { skillMap, moduleEntry },
    };
  });
}

const { skillMap, moduleEntry } = Astro.props as { skillMap: any; moduleEntry: any };
const skillMapSlug = getSkillMapSlug(skillMap);
const moduleSlug = getModuleSlug(moduleEntry);
const allEntries = (await getCollection("learn")) as Array<any>;
const modules = allEntries
  .filter(
    (entry) => isModuleEntry(entry) && getModuleSkillMapSlug(entry) === skillMapSlug && entry.data.status === "ready",
  )
  .sort((a, b) => a.data.order - b.data.order);
const currentIndex = modules.findIndex((entry) => entry.id === moduleEntry.id);
const previousModule = currentIndex > 0 ? modules[currentIndex - 1] : null;
const nextModule = currentIndex >= 0 && currentIndex < modules.length - 1 ? modules[currentIndex + 1] : null;
const { Content, headings } = await render(moduleEntry);
const visibleHeadings = headings.filter((heading: { depth: number }) => heading.depth === 2).slice(0, 12);
const progressLabels: Record<string, string> = {
  "work-in-progress": "Work in progress",
  updated: "Updated",
};
const showProgressStatus = moduleEntry.data.progressStatus !== "completed";
const progressLabel = progressLabels[moduleEntry.data.progressStatus] ?? moduleEntry.data.progressStatus;
const moduleCover = moduleEntry.data.cover;
const moduleOgImage = moduleEntry.data.ogImage || skillMap.data.ogImage;
const moduleOgImageAlt = moduleEntry.data.ogImageAlt || skillMap.data.ogImageAlt || moduleEntry.data.title;
const moduleReadTime = estimateReadTime(moduleEntry.body);
const modulePublishedAt = moduleEntry.data.pubDatetime;
const moduleAuthor = moduleEntry.data.author || SITE.author;
const moduleTitleTransitionName = `module-title-${skillMapSlug}-${moduleSlug}`;
---

<BaseLayout
  title={`${moduleEntry.data.title} | ${skillMap.data.title} | Learn | ${SITE.title}`}
  description={moduleEntry.data.description}
  image={moduleOgImage}
  imageAlt={moduleOgImageAlt}
  contentType="Article"
>
  <section class="px-4 pt-12 pb-20 md:px-8 md:pt-18 md:pb-28">
    <div class="mx-auto w-full max-w-site">
      <div class="mx-auto w-full max-w-352 xl:ml-auto xl:mr-0">
        <div class="mb-10 flex min-w-0 flex-wrap gap-3">
          <a href="/learn/" class={buttonVariants({ variant: "outline", size: "sm" })}>
            <Icon name="arrow-left" class="size-4" />
            Learn
          </a>
          <a
            href={`/learn/${skillMapSlug}/`}
            class={`${buttonVariants({ variant: "outline", size: "sm" })} max-w-full min-w-0 shrink overflow-hidden text-ellipsis`}
          >
            {skillMap.data.title}
          </a>
        </div>

        <div
          class="grid gap-10 lg:grid-cols-[16rem_minmax(0,44rem)_minmax(0,8rem)] lg:gap-12 xl:grid-cols-[18rem_minmax(0,46rem)_minmax(0,10rem)] xl:gap-16"
        >
          <aside
            class="order-2 lg:order-1 lg:sticky lg:top-28 lg:flex lg:max-h-[calc(100vh-14rem)] lg:flex-col lg:self-start"
          >
            <div class="shrink-0 rounded-lg border border-border/80 bg-background-1 p-5">
              <div class="space-y-5">
                {
                  modulePublishedAt && (
                    <div>
                      <p class="font-mono text-xs text-foreground-3 uppercase">Published</p>
                      <time class="mt-2 block text-sm text-foreground-1" datetime={modulePublishedAt.toISOString()}>
                        {formatDateUppercase(modulePublishedAt)}
                      </time>
                    </div>
                  )
                }

                <div>
                  <p class="font-mono text-xs text-foreground-3 uppercase">Read time</p>
                  <p class="mt-2 text-sm text-foreground-1">{moduleReadTime} min</p>
                </div>

                <div>
                  <p class="font-mono text-xs text-foreground-3 uppercase">Author</p>
                  <p class="mt-2 text-sm text-foreground-1">{moduleAuthor}</p>
                </div>
              </div>

              {
                moduleEntry.data.tags.length > 0 && (
                  <div class="mt-6 flex flex-wrap gap-2">
                    {moduleEntry.data.tags.map((tag: string) => (
                      <Badge variant="secondary" className="border border-border/80 bg-background-2 text-foreground-1">
                        {tag}
                      </Badge>
                    ))}
                  </div>
                )
              }

              <Button id="share-button" variant="outline" size="sm" className="mt-6 w-full justify-between">
                Share module
                <Icon name="arrow-up-right" class="size-4" />
              </Button>
            </div>

            {
              visibleHeadings.length > 0 && (
                <nav
                  aria-label="Module sections"
                  class="mt-5 flex min-h-0 flex-1 flex-col overflow-hidden rounded-lg border border-border/80 bg-background-1 p-5"
                >
                  <p class="font-mono text-xs text-foreground-3 uppercase">Sections</p>
                  <ol class="mt-4 min-h-0 flex-1 space-y-3 overflow-y-auto pr-2">
                    {visibleHeadings.map((heading: { slug: string; text: string; depth: number }) => (
                      <li>
                        <a
                          href={`#${heading.slug}`}
                          data-toc-link={heading.slug}
                          class="block border-l border-transparent py-1 pl-3 text-sm leading-snug text-foreground-2 transition-all duration-200 hover:text-accent-1"
                        >
                          {heading.text}
                        </a>
                      </li>
                    ))}
                  </ol>
                </nav>
              )
            }

          </aside>

          <article class="order-1 min-w-0 lg:order-2">
            <header>
              <h1
                class="font-display text-5xl leading-none font-semibold tracking-tighter text-foreground-0 md:text-6xl xl:text-7xl"
                transition:name={moduleTitleTransitionName}
              >
                {moduleEntry.data.title}
              </h1>
              <p class="mt-6 max-w-2xl text-lg leading-relaxed text-foreground-1 md:text-xl">
                {moduleEntry.data.description}
              </p>
            </header>

            {
              showProgressStatus && (
                <aside class="mt-8 rounded-lg border border-accent-1/35 bg-accent-1/10 p-5" aria-label="Module status">
                  <div class="flex gap-4">
                    <span class="mt-1 inline-flex size-9 shrink-0 items-center justify-center rounded-md border border-accent-1/35 bg-background-1 text-accent-1">
                      <Icon name="zap" class="size-4" />
                    </span>
                    <div>
                      <p class="font-mono text-xs tracking-[0.22em] text-accent-1 uppercase">{progressLabel}</p>
                      <p class="mt-2 text-sm leading-relaxed text-foreground-1">
                        {moduleEntry.data.progressNote ||
                          "This module is still being refined. The structure is useful, but the wording and references may continue to improve."}
                      </p>
                    </div>
                  </div>
                </aside>
              )
            }

            {
              moduleCover && (
                <div class="mt-10 overflow-hidden rounded-lg border border-border/80 bg-background-1 p-3">
                  <div class="aspect-og overflow-hidden rounded-md bg-background-0">
                    <Image
                      src={moduleCover}
                      alt={moduleEntry.data.coverAlt || moduleEntry.data.title}
                      class="h-full w-full object-cover"
                      widths={[720, 960, 1200]}
                      sizes="(min-width: 1024px) 46rem, calc(100vw - 2rem)"
                    />
                  </div>
                </div>
              )
            }

            <div class="prose mt-14 min-w-0 max-w-none">
              <Content />
            </div>

            <nav class="mt-16 grid gap-4 border-t border-border pt-8 md:grid-cols-2" aria-label="Module navigation">
              {
                previousModule ? (
                  <a
                    href={`/learn/${skillMapSlug}/${getModuleSlug(previousModule)}/`}
                    class="text-foreground-1 transition-colors hover:text-accent-1"
                  >
                    <span class="font-mono text-xs tracking-[0.24em] text-foreground-3 uppercase">Previous</span>
                    <span class="mt-3 block font-display text-xl text-foreground-0">{previousModule.data.title}</span>
                  </a>
                ) : (
                  <a href={`/learn/${skillMapSlug}/`} class="text-foreground-1 transition-colors hover:text-accent-1">
                    <span class="font-mono text-xs tracking-[0.24em] text-foreground-3 uppercase">Back</span>
                    <span class="mt-3 block font-display text-xl text-foreground-0">Return to skill map</span>
                  </a>
                )
              }

              {
                nextModule ? (
                  <a
                    href={`/learn/${skillMapSlug}/${getModuleSlug(nextModule)}/`}
                    class="text-foreground-1 transition-colors hover:text-accent-1 md:text-right"
                  >
                    <span class="font-mono text-xs tracking-[0.24em] text-foreground-3 uppercase">Next</span>
                    <span class="mt-3 block font-display text-xl text-foreground-0">{nextModule.data.title}</span>
                  </a>
                ) : (
                  <a href="/learn/" class="text-foreground-1 transition-colors hover:text-accent-1 md:text-right">
                    <span class="font-mono text-xs tracking-[0.24em] text-foreground-3 uppercase">Continue</span>
                    <span class="mt-3 block font-display text-xl text-foreground-0">Explore all maps</span>
                  </a>
                )
              }
            </nav>
          </article>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const setupShareButton = () => {
    const button = document.getElementById("share-button");
    if (!button) return;

    button.addEventListener("click", async () => {
      const url = window.location.href;
      const title = document.title;

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
        } catch {
          // Sharing was dismissed; no visible recovery is needed.
        }
        return;
      }

      try {
        await navigator.clipboard.writeText(url);
        const originalText = button.innerHTML;
        button.innerHTML = "Copied";
        window.setTimeout(() => {
          button.innerHTML = originalText;
        }, 1600);
      } catch {
        button.setAttribute("data-copy-failed", "true");
      }
    });
  };

  const setupActiveTableOfContents = () => {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"));
    if (links.length === 0) return;

    const linkById = new Map(links.map((link) => [link.dataset.tocLink, link]));
    const headings = Array.from(document.querySelectorAll<HTMLElement>(".prose :is(h2, h3)[id]")).filter((heading) =>
      linkById.has(heading.id),
    );
    if (headings.length === 0) return;

    const setActive = (id: string) => {
      for (const link of links) {
        const isActive = link.dataset.tocLink === id;
        link.classList.toggle("border-accent-1", isActive);
        link.classList.toggle("text-accent-1", isActive);
        link.classList.toggle("translate-x-1", isActive);
        link.classList.toggle("text-foreground-2", !isActive);
        link.setAttribute("aria-current", isActive ? "location" : "false");
      }
    };

    setActive(headings[0].id);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];

        if (visible?.target instanceof HTMLElement) {
          setActive(visible.target.id);
        }
      },
      {
        rootMargin: "-22% 0px -62% 0px",
        threshold: [0, 1],
      },
    );

    headings.forEach((heading) => observer.observe(heading));
    document.addEventListener("astro:before-swap", () => observer.disconnect(), { once: true });
  };

  document.addEventListener("astro:page-load", () => {
    setupShareButton();
    setupActiveTableOfContents();
  });
</script>
