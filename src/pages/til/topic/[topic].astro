---
import { getCollection } from "astro:content"
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageIntro from "@/components/common/PageIntro.astro"
import TilCard from "@/components/til/TilCard.astro"
import TopicPill from "@/components/til/TopicPill.astro"
import { slugifyTopic } from "@/lib/slug"
import { SITE } from "@data/config"

export async function getStaticPaths() {
  const notes = (await getCollection("til")).filter((entry) => !entry.data.draft)
  const topics = [...new Map(notes.map((entry) => [slugifyTopic(entry.data.topic), entry.data.topic])).entries()]
  return topics.map(([topicSlug, topic]) => ({ params: { topic: topicSlug }, props: { topic } }))
}

const { topic } = Astro.props as { topic: string }
const notes = (await getCollection("til"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf())
const filtered = notes.filter((entry) => slugifyTopic(entry.data.topic) === slugifyTopic(topic))
const topicCounts = notes.reduce<Record<string, number>>((acc, entry) => {
  acc[entry.data.topic] = (acc[entry.data.topic] ?? 0) + 1
  return acc
}, {})
const topics = Object.entries(topicCounts).sort(([a], [b]) => a.localeCompare(b))
---

<BaseLayout
  title={`${topic} TIL | ${SITE.title}`}
  description={`Short Today I Learned notes about ${topic.toLowerCase()}.`}
>
  <section class="px-4 pt-8 pb-20 md:px-8 md:pt-12 md:pb-28">
    <div class="mx-auto w-full max-w-site">
      <PageIntro
        title={`Notes on ${topic}.`}
        description="A focused shelf of small discoveries, observations, and mental hooks around this topic."
        class="min-h-44 md:h-52"
      />

      <section aria-labelledby="topic-til" class="mt-14 md:mt-16">
        <div class="mb-8 flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
          <h2 id="topic-til" class="sr-only">{topic} notes</h2>
          <nav aria-label="TIL topics" class="flex flex-wrap gap-2">
            <TopicPill href="/til/" label="All" count={notes.length} />
            {topics.map(([topicName, count]) => <TopicPill href={`/til/topic/${slugifyTopic(topicName)}/`} label={topicName} count={count} active={slugifyTopic(topicName) === slugifyTopic(topic)} />)}
          </nav>
        </div>

        <div class="grid items-stretch gap-6 md:grid-cols-2 xl:grid-cols-3">
          {filtered.map((entry) => <TilCard entry={entry} />)}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
