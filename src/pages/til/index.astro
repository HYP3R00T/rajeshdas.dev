---
import { getCollection } from "astro:content";
import SectionHeader from "@/components/core/SectionHeader.astro";
import NoteArchive from "@/components/til/NoteArchive.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@data/config";

const notes = (await getCollection("til"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());

const topicCounts = notes.reduce<Record<string, number>>((acc, entry) => {
  acc[entry.data.topic] = (acc[entry.data.topic] ?? 0) + 1;
  return acc;
}, {});
const topics = Object.entries(topicCounts).sort(([a], [b]) => a.localeCompare(b));
---

<BaseLayout
  title={`Notes | ${SITE.title}`}
  description="Short notes from the things Rajesh learns across engineering, language, physics, math, and nearby curiosities."
>
  <section aria-labelledby="notes-title">
    <div class="site-grid-frame">
      <SectionHeader
        eyebrow="Notes"
        title="Small discoveries worth keeping close."
        titleId="notes-title"
        headingLevel={1}
        description="Brief observations, useful mental hooks, and lessons gathered while working through systems, language, tools, and nearby curiosities."
      />
    </div>
  </section>

  <NoteArchive notes={notes} allNotes={notes} topics={topics} />
</BaseLayout>
