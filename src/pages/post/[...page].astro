---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { PaginateFunction } from "astro";
import { getCollection } from "astro:content";
import type { PostsPageProps } from "@/lib/types";
import PageIntro from "@/components/common/PageIntro.astro";
import Pagination from "@/components/post/Pagination.astro";
import PostCard from "@/components/post/PostCard.astro";
import FeaturedPostCard from "@/components/post/FeaturedPostCard.astro";
import { SITE } from "@data/config";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const posts = await getCollection("posts").then((entries) => entries.filter((entry) => !entry.data.draft));

  posts.sort((a, b) => {
    const aDate = new Date(a.data.pubDatetime).valueOf();
    const bDate = new Date(b.data.pubDatetime).valueOf();
    return bDate - aDate;
  });

  const featured = posts.find((p) => p.data.featured);
  const rest = featured ? posts.filter((p) => p.id !== featured.id) : posts;
  const pagination = paginate(rest, { pageSize: SITE.pageSize });

  return pagination.map((page) => ({
    ...page,
    props: {
      ...page.props,
      totalPages: pagination.length,
      featured,
      page: {
        ...page.props.page,
        pageSize: SITE.pageSize,
      },
    },
  }));
}

const { page, totalPages, featured } = Astro.props as PostsPageProps;
const defaultPageSize = SITE.pageSize ?? 10;
const pageSize = page.pageSize ?? defaultPageSize;
const pageOffset = (page.currentPage - 1) * pageSize;
const articleTotalPages = totalPages ?? 1;
const hasFeaturedPanel = Boolean(featured && page.currentPage === 1);
---

<BaseLayout>
  <div class={hasFeaturedPanel ? "articles-index" : ""}>
    <section
      class="px-4 pt-8 pb-20 md:px-8 md:pt-12 md:pb-28"
      data-articles-featured={hasFeaturedPanel ? "true" : undefined}
    >
      <div
        class:list={[
          "mx-auto w-full max-w-site",
          hasFeaturedPanel ? "space-y-14 md:space-y-16" : "space-y-14 md:space-y-18",
        ]}
      >
        <PageIntro
          title="Field notes for systems that need to survive reality."
          description="Longer essays on engineering decisions, systems thinking, automation, and the tradeoffs behind practical work."
        />

        {
          featured && page.currentPage === 1 && (
            <section aria-label="Featured article" class="max-w-5xl">
              <FeaturedPostCard post={featured} />
            </section>
          )
        }
      </div>
    </section>

    <section
      id="all-articles-panel"
      aria-labelledby="all-articles"
      class="px-4 pt-16 pb-20 md:px-8 md:pt-24 md:pb-28"
      data-articles-list
    >
      <div class="mx-auto w-full max-w-site space-y-5">
        <div>
          <h2 id="all-articles" class="font-display text-2xl text-foreground-0 md:text-3xl">All field notes</h2>
        </div>

        <div class="grid items-stretch gap-4 md:grid-cols-2 xl:grid-cols-3 xl:gap-5">
          {page.data.map((post, index) => <PostCard post={post} index={pageOffset + index} />)}
        </div>

        {
          articleTotalPages > 1 && (
            <Pagination
              currentPage={page.currentPage}
              prevUrl={page.url.prev}
              nextUrl={page.url.next}
              totalPages={articleTotalPages}
            />
          )
        }
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  declare global {
    interface Window {
      __articlesPanelSnapCleanup?: () => void;
    }
  }

  const setupArticlesPanelSnap = () => {
    window.__articlesPanelSnapCleanup?.();

    const root = document.querySelector(".articles-index");
    const featuredPanel = document.querySelector<HTMLElement>("[data-articles-featured='true']");
    const listPanel = document.querySelector<HTMLElement>("[data-articles-list]");
    const canSnap = window.matchMedia("(min-width: 1024px) and (prefers-reduced-motion: no-preference)");

    if (!root || !featuredPanel || !listPanel || !canSnap.matches) return;

    let isSnapping = false;
    let releaseTimer = 0;

    const scrollToPanel = (target: HTMLElement) => {
      isSnapping = true;
      window.clearTimeout(releaseTimer);
      const top = Math.max(0, window.scrollY + target.getBoundingClientRect().top);
      window.scrollTo({ top, behavior: "smooth" });
      releaseTimer = window.setTimeout(() => {
        isSnapping = false;
      }, 850);
    };

    const onWheel = (event: WheelEvent) => {
      if (event.ctrlKey || event.metaKey || event.altKey) return;
      if (Math.abs(event.deltaX) > Math.abs(event.deltaY)) return;
      if (Math.abs(event.deltaY) < 12) return;

      const direction = event.deltaY > 0 ? 1 : -1;
      const currentY = window.scrollY;
      const listTop = currentY + listPanel.getBoundingClientRect().top;
      const beforeArchive = currentY < listTop - 24;
      const nearArchiveStart = currentY >= listTop - 120 && currentY <= listTop + 160;

      if (direction === 1 && beforeArchive) {
        event.preventDefault();
        if (!isSnapping) scrollToPanel(listPanel);
        return;
      }

      if (direction === -1 && nearArchiveStart) {
        event.preventDefault();
        if (!isSnapping) scrollToPanel(featuredPanel);
      }
    };

    const onMediaChange = () => {
      if (!canSnap.matches) window.__articlesPanelSnapCleanup?.();
    };

    window.addEventListener("wheel", onWheel, { passive: false });
    canSnap.addEventListener("change", onMediaChange);

    window.__articlesPanelSnapCleanup = () => {
      window.removeEventListener("wheel", onWheel);
      canSnap.removeEventListener("change", onMediaChange);
      window.clearTimeout(releaseTimer);
      isSnapping = false;
      window.__articlesPanelSnapCleanup = undefined;
    };
  };

  document.addEventListener("astro:page-load", setupArticlesPanelSnap);
</script>
