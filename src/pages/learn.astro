---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SkillMapCard from "@/components/learn/SkillMapCard.astro";
import { getModuleSkillMapSlug, getSkillMapSlug, isModuleEntry, isSkillMapEntry } from "@/lib/learn";
import { SITE } from "@data/config";

const entries = await getCollection("learn");
const skillMaps = entries
  .filter((entry) => isSkillMapEntry(entry) && entry.data.status === "ready")
  .sort((a, b) => a.data.order - b.data.order);
const modules = entries.filter((entry) => isModuleEntry(entry) && entry.data.status === "ready");
const getModuleCount = (skillMap: (typeof skillMaps)[number]) => modules.filter((module) => getModuleSkillMapSlug(module) === getSkillMapSlug(skillMap)).length;
const featuredMap = skillMaps[0];
const remainingMaps = skillMaps.slice(1);
---

<BaseLayout title={`Learn | ${SITE.title}`} description="Curated technical skill maps for learning what matters, why it matters, and where to go next.">
  <section class="px-4 pt-16 pb-20 md:px-8 md:pt-24 md:pb-28">
    <div class="mx-auto w-full max-w-site">
      <header class="max-w-3xl">
        <p class="font-mono text-xs tracking-[0.28em] text-accent-1 uppercase">Learn</p>
        <h1 class="mt-6 font-display text-5xl leading-none font-semibold tracking-tighter text-foreground-0 md:text-6xl xl:text-7xl">
          Learn by following a map, not a pile of links.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-foreground-1">
          Curated paths for building practical engineering judgment, one focused module at a time.
        </p>
      </header>

      <section aria-labelledby="recommended-map" class="mt-20">
        <h2 id="recommended-map" class="sr-only">Recommended skill map</h2>
        <div class="max-w-3xl">
          {featuredMap ? <SkillMapCard map={featuredMap} moduleCount={getModuleCount(featuredMap)} /> : <p class="text-foreground-1">No skill maps are ready yet.</p>}
        </div>
      </section>

      {
        remainingMaps.length > 0 && (
          <section aria-labelledby="all-skill-maps" class="mt-20">
            <p class="font-mono text-xs tracking-[0.28em] text-accent-1 uppercase">Library</p>
            <h2 id="all-skill-maps" class="mt-3 font-display text-3xl text-foreground-0 md:text-4xl">All skill maps</h2>
            <div class="mt-8 grid gap-6 md:grid-cols-2">
              {remainingMaps.map((map) => <SkillMapCard map={map} moduleCount={getModuleCount(map)} />)}
            </div>
          </section>
        )
      }
    </div>
  </section>
</BaseLayout>
