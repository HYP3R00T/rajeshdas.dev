---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/core/SectionHeader.astro";
import SiteSection from "@/components/core/SiteSection.astro";
import SkillMapCard from "@/components/learn/SkillMapCard.astro";
import { getModuleSkillMapSlug, getSkillMapSlug, isModuleEntry, isSkillMapEntry } from "@/lib/learn";
import { SITE } from "@data/config";

const entries = await getCollection("learn");
const skillMaps = entries
  .filter((entry) => isSkillMapEntry(entry) && entry.data.status === "ready")
  .sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title));
const modules = entries.filter((entry) => isModuleEntry(entry) && entry.data.status === "ready");
const getModuleCount = (skillMap: (typeof skillMaps)[number]) =>
  modules.filter((module) => getModuleSkillMapSlug(module) === getSkillMapSlug(skillMap)).length;
---

<BaseLayout title={`Learn | ${SITE.title}`} description="Curated technical skill maps for learning what matters, why it matters, and where to go next.">
  <section aria-labelledby="learn-title">
    <div class="site-grid-frame">
      <SectionHeader
        eyebrow="Learn"
        title="Learn by following a map, not a pile of links."
        titleId="learn-title"
        headingLevel={1}
        description="Curated paths for building practical engineering judgment, one focused module at a time."
      />
    </div>
  </section>

  {
    skillMaps.length > 0 ? (
      <SiteSection aria-label="Skill maps" frameClass="grid xl:grid-cols-2">
        {skillMaps.map((map) => <SkillMapCard map={map} moduleCount={getModuleCount(map)} />)}
      </SiteSection>
    ) : (
      <SiteSection aria-label="Skill maps">
        <p class="px-5 py-16 text-foreground-2 md:px-10 lg:px-15">No skill maps are ready yet.</p>
      </SiteSection>
    )
  }
</BaseLayout>
